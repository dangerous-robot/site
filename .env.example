# Sample environment file for the dr pipeline. Copy to .env and fill in.
# .env is gitignored; .env.example is checked in.

# --- Provider selection ----------------------------------------------------
# Default model spec for the dr CLI (overridden by --model). Examples:
#   anthropic:claude-haiku-4-5-20251001   (default if unset)
#   infomaniak:openai/gpt-oss-120b
DR_MODEL=

# Per-agent overrides (optional). Each falls back to DR_MODEL/--model.
# Example: run analyst on gpt-oss-120b, auditor on the cheaper Mistral.
#   DR_ANALYST_MODEL=infomaniak:openai/gpt-oss-120b
#   DR_AUDITOR_MODEL=infomaniak:mistral24b
# Use Infomaniak's short aliases (mistral24b, mistral3, gemma3n, llama3,
# granite, qwen3) or full HF slugs (e.g. mistralai/Ministral-3-14B-Instruct-2512).
# Run `dr --model infomaniak:badname verify-claim "x"` to see the live valid list
# in the error response.
# Note: gemma3n on Infomaniak cannot do tool calls today (gateway config),
# so use it only for analyst/auditor, not researcher/ingestor.
DR_RESEARCHER_MODEL=
DR_ANALYST_MODEL=
DR_AUDITOR_MODEL=
DR_INGESTOR_MODEL=

# --- Anthropic (default provider) ------------------------------------------
# Required when DR_MODEL is unset, anthropic:..., or a bare model name.
ANTHROPIC_API_KEY=

# --- Brave Search ----------------------------------------------------------
# Required for `dr research` regardless of provider (researcher web_search tool).
BRAVE_WEB_SEARCH_API_KEY=

# --- Infomaniak (optional, multi-provider Part 1) --------------------------
# Required when DR_MODEL starts with infomaniak:.
INFOMANIAK_API_KEY=
INFOMANIAK_PRODUCT_ID=
# Defaults to "2" if unset.
INFOMANIAK_API_VERSION=2
