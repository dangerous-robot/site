---
import Base from './Base.astro';
import Wallpaper, { type WallpaperVariant } from '../components/Wallpaper.astro';
import PaperGrain from '../components/PaperGrain.astro';
import '../styles/resources.css';

type Layout = 'reading' | 'wide' | 'bare';

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  lede?: string;
  wallpaper?: WallpaperVariant;
  layout?: Layout;
  noindex?: boolean;
  /** Hide the visual h1 (kept in <title>) and let `lede` carry the hero. */
  hideTitle?: boolean;
}

const {
  title,
  description,
  eyebrow,
  lede,
  wallpaper = 'default',
  layout = 'reading',
  noindex = false,
  hideTitle = false,
} = Astro.props;
---
<Base title={title} description={description} layout={layout} noindex={noindex}>
  <Wallpaper variant={wallpaper} />
  <PaperGrain />
  <div class="resources-page">
    <header class:list={['resources-hero', hideTitle && 'resources-hero--lede-hero']} id="top">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      {!hideTitle && <h1>{title}</h1>}
      {lede && <p class="lede">{lede}</p>}
    </header>
    <slot />
  </div>
</Base>
