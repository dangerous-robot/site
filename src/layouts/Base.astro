---
import "../styles/tokens.css";
import "../styles/global.css";
import A11yControl from "../components/A11yControl.astro";

interface Props {
  title: string;
  description?: string;
  /** 'reading' (default): narrow centered column. 'wide': expanded list/matrix width. */
  layout?: 'reading' | 'wide';
}

const { title, description = "Structured research backing claims about AI products and companies.", layout = 'reading' } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark" data-contrast="normal" data-font-size="medium">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - Dangerous Robot</title>
    <meta name="description" content={description} />

    <!-- Synchronous: prevents flash of wrong theme before CSS paints.
         Storage keys and font-size values mirror A11yControl.astro. -->
    <script is:inline>
      (function () {
        var html = document.documentElement;
        function read(key) {
          try { return localStorage.getItem(key); } catch (e) { return null; }
        }

        var storedTheme = read("dr-theme") || "system";
        html.dataset.theme = storedTheme === "system"
          ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
          : storedTheme;
        html.dataset.themeChoice = storedTheme;

        html.dataset.contrast = read("dr-contrast") || "normal";

        var storedSize = read("dr-font-size") || "medium";
        html.dataset.fontSize = storedSize;
        html.style.fontSize = storedSize === "small" ? "16px"
          : storedSize === "large" ? "20px"
          : "18px";
      })();
    </script>
  </head>
  <body>
    <nav class="site-nav">
      <div class="nav-inner">
        <a href="/" class="site-name">Dangerous Robot</a>
        <ul class="nav-links">
          <li><a href="/companies">Companies</a></li>
          <li><a href="/products">Products</a></li>
          <li><a href="/claims">Claims</a></li>
          <li><a href="/standards">Standards</a></li>
          <li><a href="/topics">Topics</a></li>
        </ul>
      </div>
    </nav>

    <main class={`content content--${layout}`}>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Dangerous Robot is a research project from <a href="https://treadlightly.ai">TreadLightly AI</a>
        &nbsp;·&nbsp;
        <a href="/sources">Sources</a>
        &nbsp;·&nbsp;
        <a href="https://github.com/bfaloona/dangerous-robot" target="_blank" rel="noopener noreferrer">GitHub</a>
      </p>
    </footer>

    <A11yControl />

    <style>
      .site-nav {
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-md) 0;
        background: var(--color-surface);
      }

      .nav-inner {
        max-width: var(--content-max-width);
        margin: 0 auto;
        padding: 0 var(--space-lg);
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .site-name {
        font-family: var(--font-heading);
        font-size: 1.15rem;
        font-weight: bold;
        color: var(--color-site-name);
        text-decoration: none;
        /* Flair: 2px accent bar on left edge of site name */
        border-left: 2px solid var(--color-accent);
        padding-left: 0.5rem;
      }

      .site-name:hover {
        text-decoration: none;
        color: var(--color-text);
      }

      .nav-links {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: var(--space-lg);
      }

      .nav-links a {
        color: var(--color-nav-link);
        font-size: var(--font-size-sm);
        text-decoration: none;
      }

      .nav-links a:hover {
        color: var(--color-nav-link-hover);
        text-decoration: none;
      }

      .content {
        max-width: var(--content-max-width);
        margin: 0 auto;
        padding: var(--space-xl) var(--space-lg);
      }

      .content--wide {
        max-width: var(--content-max-width-wide, 72rem);
      }

      .content--reading {
        max-width: var(--content-max-width-reading, var(--content-max-width));
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: var(--space-xl) 0;
        text-align: center;
        color: var(--color-footer-text);
        font-size: 0.85rem;
      }

      .site-footer a {
        color: var(--color-footer-link);
        text-decoration: none;
      }

      .site-footer a:hover {
        color: var(--color-footer-link-hover);
      }

      /* Prevent horizontal scroll at narrow viewports */
      @media (max-width: 400px) {
        .nav-inner,
        .content {
          padding-left: var(--space-md);
          padding-right: var(--space-md);
        }
      }
    </style>
  </body>
</html>
