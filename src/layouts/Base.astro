---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import "../styles/tokens.css";
import "../styles/global.css";
import A11yControl from "../components/A11yControl.astro";

const siteVersion = readFileSync(resolve('VERSION.md'), 'utf-8').split('\n')[0].trim();

interface Props {
  title: string;
  description?: string;
  /** 'reading' (default): narrow centered column. 'wide': expanded list/matrix width. 'bare': no constraints, for bespoke layouts. */
  layout?: 'reading' | 'wide' | 'bare';
  /** 'standard' (default): render the top site-nav. 'minimal': page provides its own chrome. */
  chrome?: 'standard' | 'minimal';
  ogImage?: string;
}

const {
  title,
  description = "Dangerous Robot is a structured research hub tracking AI company environmental and safety claims. Built for journalists, researchers, and policy teams.",
  layout = 'reading',
  chrome = 'standard',
  ogImage = '/dr-logo.png',
} = Astro.props;

const ogTitle = `${title} - Dangerous Robot`;
const ogImageAbsolute = new URL(ogImage, Astro.site).href;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Dangerous Robot",
  "url": "https://dangerousrobot.org",
  "logo": "https://dangerousrobot.org/dr-logo.png",
  "sameAs": ["https://github.com/dangerous-robot/site"],
};
---

<!doctype html>
<html lang="en" data-theme="dark" data-contrast="normal" data-font-size="medium">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - Dangerous Robot</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={Astro.url.href} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <!-- Organization structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style"
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;700;800&display=swap"
      onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
      <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600;700;800&display=swap" />
    </noscript>

    <!-- Synchronous: prevents flash of wrong theme before CSS paints.
         Storage keys and font-size values mirror A11yControl.astro. -->
    <script is:inline>
      (function () {
        var html = document.documentElement;
        function read(key) {
          try { return localStorage.getItem(key); } catch (e) { return null; }
        }

        var storedTheme = read("dr-theme") || "system";
        html.dataset.theme = storedTheme === "system"
          ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
          : storedTheme;
        html.dataset.themeChoice = storedTheme;

        html.dataset.contrast = read("dr-contrast") || "normal";

        var storedSize = read("dr-font-size") || "medium";
        html.dataset.fontSize = storedSize;
        html.style.fontSize = storedSize === "small" ? "16px"
          : storedSize === "large" ? "20px"
          : "18px";

        html.dataset.motion = read("dr-motion") || "on";
      })();
    </script>
  </head>
  <body>
    <div class="alpha-banner" role="status">
      <span class="alpha-tag">PRE-RELEASE ALPHA</span>
      <span>This site is in active development.</span>
      <a href="https://github.com/dangerous-robot/site" target="_blank" rel="noopener noreferrer">Fork me on GitHub</a>
    </div>
    {chrome === 'standard' && (
      <nav class="site-nav">
        <div class="nav-inner">
          <a href="/" class="site-name">
            <img src="/dr-logo.png" alt="" class="site-logo" aria-hidden="true" />
            Dangerous Robot
          </a>
          <ul class="nav-links" id="nav-links">
            <li><a href="/companies">Companies</a></li>
            <li><a href="/products">Products</a></li>
            <li><a href="/topics">Topics</a></li>
            <li><a href="/claims">Claims</a></li>
            <li><a href="/sources">Sources</a></li>
            <li><a href="/criteria">Criteria</a></li>
            <li><a href="/faq">FAQ</a></li>
          </ul>
          <button class="nav-toggle" id="nav-toggle" aria-label="Toggle navigation" aria-expanded="false" aria-controls="nav-links">
            <span aria-hidden="true">&#9776;</span>
          </button>
        </div>
      </nav>
      <script is:inline>
        (function () {
          var toggle = document.getElementById('nav-toggle');
          var links = document.getElementById('nav-links');
          if (toggle && links) {
            toggle.addEventListener('click', function () {
              var open = links.classList.toggle('nav-open');
              toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            });
          }
        })();
      </script>
    )}

    <main class={`content content--${layout}`}>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Dangerous Robot is a research project sponsored by <a href="https://treadlightly.ai">TreadLightly AI</a>
      </p>
      <p>
        <a href="/values">Values</a>
        &nbsp;·&nbsp;
        <a href="/faq#methodology">Methodology</a>
        &nbsp;·&nbsp;
        <a href="/credits">Credits</a>
      </p>
      <p>
        <a href="https://github.com/dangerous-robot/site" target="_blank" rel="noopener noreferrer">GitHub</a>
        &nbsp;·&nbsp;
        <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener noreferrer">CC-BY-4.0</a>
        &nbsp;·&nbsp;
        v{siteVersion}
      </p>
    </footer>

    <A11yControl />

    <style>
      .alpha-banner {
        background: var(--color-accent);
        color: var(--color-surface);
        padding: var(--space-xs) var(--space-lg);
        font-family: var(--font-mono);
        font-size: var(--font-size-2xs);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        text-align: center;
        display: flex;
        gap: var(--space-sm);
        justify-content: center;
        align-items: baseline;
        flex-wrap: nowrap;
        white-space: nowrap;
        overflow: hidden;
      }

      .alpha-tag {
        font-weight: 700;
        letter-spacing: 0.18em;
        margin-inline-end: var(--space-xs);
        flex-shrink: 0;
      }

      .alpha-banner a {
        color: inherit;
        text-decoration: underline;
      }

      .alpha-banner a:hover {
        text-decoration: none;
      }

      @media (max-width: 880px) {
        .alpha-banner > span:not(.alpha-tag),
        .alpha-banner > a {
          display: none;
        }
      }

      .site-nav {
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-md) 0;
        background: var(--color-surface);
      }

      .nav-inner {
        padding: 0 var(--space-lg);
        display: flex;
        align-items: center;
        gap: var(--space-md);
      }

      .site-name {
        font-family: var(--font-wordmark);
        font-size: 1.15rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        color: var(--color-site-name);
        text-decoration: none;
        display: flex;
        align-items: center;
        white-space: nowrap;
        /* Flair: 2px accent bar on left edge of site name */
        border-left: 2px solid var(--color-accent);
        padding-left: 0.5rem;
        margin-right: auto;
      }

      .site-logo {
        height: 34px;
        width: 34px;
        object-fit: contain;
        /* Visual size +44% (1.2 × 1.2), layout box unchanged */
        transform: scale(1.44);
        transform-origin: center;
        margin: 0 1em;
        opacity: 0.72;
      }

      :global([data-theme="dark"]) .site-logo {
        filter: invert(1) brightness(0.85);
        opacity: 0.72;
      }

      .site-name:hover {
        text-decoration: none;
        color: var(--color-text);
      }

      .nav-links {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: var(--space-lg);
        margin-left: auto;
      }

      .nav-links a {
        color: var(--color-nav-link);
        font-size: var(--font-size-sm);
        text-decoration: none;
      }

      .nav-links a:hover {
        color: var(--color-nav-link-hover);
        text-decoration: none;
      }

      .content {
        max-width: var(--content-max-width);
        margin: 0 auto;
        padding: var(--space-xl) var(--space-lg);
      }

      .content--wide {
        max-width: var(--content-max-width-wide, 72rem);
      }

      .content--reading {
        max-width: var(--content-max-width-reading, var(--content-max-width));
      }

      .content--bare {
        max-width: none;
        padding: 0;
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: var(--space-md) 0;
        text-align: center;
        color: var(--color-footer-text);
        font-family: var(--font-mono);
        font-size: var(--font-size-2xs);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        line-height: 1.4;
      }

      .site-footer p {
        margin: var(--space-xs) 0;
      }

      .site-footer a {
        color: var(--color-footer-link);
        text-decoration: none;
      }

      .site-footer a:hover {
        color: var(--color-footer-link-hover);
      }

      .nav-toggle {
        display: none;
        background: none;
        border: none;
        color: var(--color-nav-link);
        font-size: 1.4rem;
        line-height: 1;
        padding: var(--space-xs) var(--space-sm);
        cursor: pointer;
      }

      .nav-toggle:hover {
        color: var(--color-nav-link-hover);
      }

      @media (max-width: 768px) {
        .site-nav {
          position: relative;
        }

        .nav-toggle {
          display: flex;
          align-items: center;
        }

        .site-logo {
          margin: 0 var(--space-sm);
        }

        .nav-links {
          display: none;
          flex-direction: column;
          gap: 0;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: var(--color-surface);
          border-bottom: 1px solid var(--color-border);
          padding: var(--space-sm) var(--space-lg) var(--space-md);
          z-index: 100;
        }

        .nav-links.nav-open {
          display: flex;
        }

        .nav-links li {
          border-top: 1px solid var(--color-border);
        }

        .nav-links a {
          display: block;
          padding: var(--space-sm) 0;
          font-size: var(--font-size-base);
        }

        .nav-inner,
        .content {
          padding-left: var(--space-md);
          padding-right: var(--space-md);
        }
      }
    </style>
  </body>
</html>
