---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import "../styles/tokens.css";
import "../styles/global.css";
import A11yControl from "../components/A11yControl.astro";

const siteVersion = readFileSync(resolve('VERSION.md'), 'utf-8').split('\n')[0].trim();
const googleFontsUrl = "https://fonts.googleapis.com/css2?family=Orbitron:wght@600;700;800&family=Space+Grotesk:wght@600&display=swap";

interface Props {
  title: string;
  description?: string;
  /** 'reading' (default): narrow centered column. 'wide': expanded list/matrix width. 'bare': no constraints, for bespoke layouts. */
  layout?: 'reading' | 'wide' | 'bare';
  /** 'standard' (default): render the top site-nav. 'minimal': page provides its own chrome. */
  chrome?: 'standard' | 'minimal';
  ogImage?: string;
  /** When true, emit `noindex,nofollow`. Default false (indexable). */
  noindex?: boolean;
}

const {
  title,
  description = "Dangerous Robot is a structured research hub tracking AI company environmental and safety claims. Built for journalists, researchers, and policy teams.",
  layout = 'reading',
  chrome = 'standard',
  ogImage = '/dr-logo.png',
  noindex = false,
} = Astro.props;

const ogTitle = `${title} - Dangerous Robot`;
const ogImageAbsolute = new URL(ogImage, Astro.site).href;

type NavLink = { href: string; label: string };
type Section = { href: string; label: string; links: NavLink[] };

const TOP_LINKS: NavLink[] = [
  { href: '/research',  label: 'Research' },
  { href: '/resources', label: 'Resources' },
];

const SECTIONS: Section[] = [
  {
    href: '/research',
    label: 'Research',
    links: [
      { href: '/research/topics',      label: 'Topics' },
      { href: '/research/claims',      label: 'Claims' },
      { href: '/research/companies',   label: 'Companies' },
      { href: '/research/products',    label: 'Products' },
      { href: '/values',               label: 'Values' },
    ],
  },
  {
    href: '/resources',
    label: 'Resources',
    links: [
      { href: '/resources/should-i',       label: 'Should I Use AI?' },
      { href: '/resources/ai-safety',      label: 'AI Safety Index' },
      { href: '/resources/turn-off-ai',    label: 'Turn Off AI' },
      { href: '/resources/responsible-ai', label: 'Responsible AI' },
    ],
  },
];

const pathname = Astro.url.pathname;
const currentSection = SECTIONS.find(
  (s) => pathname === s.href || pathname.startsWith(s.href + '/') || s.links.some(l => pathname === l.href),
) ?? null;
const navLinks: NavLink[] = currentSection?.links ?? [];

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Dangerous Robot",
  "url": "https://dangerousrobot.org",
  "logo": "https://dangerousrobot.org/dr-logo.png",
  "sameAs": ["https://github.com/dangerous-robot/site"],
};
---

<!doctype html>
<html lang="en" data-theme="dark" data-contrast="normal" data-font-size="medium">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - Dangerous Robot</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={Astro.url.href} />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large'} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Dangerous Robot" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageAbsolute} />
    <meta property="og:image:alt" content="Dangerous Robot logo" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />
    <!-- Organization structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style"
      href={googleFontsUrl}
      onload="this.onload=null;this.rel='stylesheet'" />
    <noscript>
      <link rel="stylesheet" href={googleFontsUrl} />
    </noscript>

    <!-- Synchronous: prevents flash of wrong theme before CSS paints.
         Storage keys and font-size values mirror A11yControl.astro. -->
    <script is:inline>
      (function () {
        var html = document.documentElement;
        function read(key) {
          try { return localStorage.getItem(key); } catch (e) { return null; }
        }

        var storedTheme = read("dr-theme") || "system";
        html.dataset.theme = storedTheme === "system"
          ? (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light")
          : storedTheme;
        html.dataset.themeChoice = storedTheme;

        html.dataset.contrast = read("dr-contrast") || "normal";

        var storedSize = read("dr-font-size") || "medium";
        html.dataset.fontSize = storedSize;
        html.style.fontSize = storedSize === "small" ? "16px"
          : storedSize === "large" ? "20px"
          : "18px";

        html.dataset.motion = read("dr-motion") || "on";
      })();
    </script>
  </head>
  <body>
    <div class="alpha-banner" role="status">
      <span class="alpha-tag">BETA RELEASE</span>
    </div>
    {chrome === 'standard' && (
      <Fragment>
        <a href="#main-content" class="skip-nav">Skip to main content</a>
        <nav class="site-nav" aria-label="Site navigation">
          <div class="nav-inner">
            <div class="site-name-group">
              <a href="/" class="site-name">
                <img src="/dr-logo.png" alt="" class="site-logo" aria-hidden="true" />
                Dangerous Robot
              </a>
            </div>
            <div class="nav-links" id="nav-links">
              <ul class="nav-top-links" role="list">
                {TOP_LINKS.map((l) => (
                  <li class="nav-section-item">
                    <a href={l.href} aria-current={
                      pathname === l.href ? 'page' :
                      currentSection?.href === l.href ? 'true' : undefined
                    }>
                      {l.label}
                    </a>
                  </li>
                ))}
              </ul>
              {navLinks.length > 0 && (
                <ul class="nav-sub-links" role="list">
                  {navLinks.map((l) => (
                    <li>
                      <a href={l.href} aria-current={pathname === l.href ? 'page' : undefined}>
                        {l.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
              <div class="nav-dropdown-sections">
                {SECTIONS.map((s) => (
                  <div class="dropdown-section">
                    <a
                      class="dropdown-section-label"
                      href={s.href}
                      aria-current={
                        pathname === s.href ? 'page' :
                        currentSection?.href === s.href ? 'true' : undefined
                      }
                    >
                      {s.label}
                    </a>
                    <ul class="dropdown-section-links" role="list">
                      {s.links.map((l) => (
                        <li>
                          <a href={l.href} aria-current={pathname === l.href ? 'page' : undefined}>
                            {l.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
            <button
              class="nav-toggle"
              id="nav-toggle"
              aria-label="Open navigation menu"
              aria-expanded="false"
              aria-controls="nav-links"
            >
              <svg aria-hidden="true" focusable="false" width="20" height="14" viewBox="0 0 20 14" fill="none">
                <rect y="0" width="20" height="2" rx="1" fill="currentColor"/>
                <rect y="6" width="20" height="2" rx="1" fill="currentColor"/>
                <rect y="12" width="20" height="2" rx="1" fill="currentColor"/>
              </svg>
            </button>
          </div>
        </nav>
        <script is:inline>
          (function () {
            var nav = document.querySelector('.site-nav');
            var toggle = document.getElementById('nav-toggle');
            var links = document.getElementById('nav-links');
            var nameGroup = nav ? nav.querySelector('.site-name-group') : null;

            if (!nav || !toggle || !links || !nameGroup) return;

            var navInner = nav.querySelector('.nav-inner');

            function closeMenu() {
              links.classList.remove('nav-open');
              toggle.setAttribute('aria-expanded', 'false');
              toggle.setAttribute('aria-label', 'Open navigation menu');
            }

            function openMenu() {
              links.classList.add('nav-open');
              toggle.setAttribute('aria-expanded', 'true');
              toggle.setAttribute('aria-label', 'Close navigation menu');
              var dropdownSections = links.querySelector('.nav-dropdown-sections');
              var firstLink = (dropdownSections || links).querySelector('a');
              if (firstLink) firstLink.focus();
            }

            var linksNaturalWidth = 0;

            function measureLinks() {
              var gap = parseFloat(getComputedStyle(links).gap) || 8;
              var clone = links.cloneNode(true);
              Object.assign(clone.style, {
                position: 'fixed',
                left: '-9999px',
                top: '0',
                display: 'flex',
                flexDirection: 'row',
                visibility: 'hidden',
                width: 'max-content',
                gap: gap + 'px',
                margin: '0',
                padding: '0',
              });
              var childLists = clone.querySelectorAll('ul');
              for (var i = 0; i < childLists.length; i++) {
                childLists[i].style.flex = 'none';
              }
              document.body.appendChild(clone);
              linksNaturalWidth = clone.offsetWidth;
              document.body.removeChild(clone);
            }

            function updateCollapsed() {
              if (!linksNaturalWidth) measureLinks();
              var navWidth = nav.offsetWidth;
              var nameWidth = nameGroup.offsetWidth;
              var padding = navInner ? parseFloat(getComputedStyle(navInner).paddingLeft) * 2 : 48;
              var gap = navInner ? (parseFloat(getComputedStyle(navInner).gap) || 16) : 16;
              var needed = nameWidth + gap + linksNaturalWidth + padding + 56;

              if (needed > navWidth) {
                nav.classList.add('nav--collapsed');
              } else {
                nav.classList.remove('nav--collapsed');
                closeMenu();
              }
            }

            if (window.ResizeObserver) {
              new ResizeObserver(updateCollapsed).observe(nav);
            }
            requestAnimationFrame(updateCollapsed);

            toggle.addEventListener('click', function () {
              if (links.classList.contains('nav-open')) {
                closeMenu();
              } else {
                openMenu();
              }
            });

            document.addEventListener('keydown', function (e) {
              if (e.key === 'Escape' && links.classList.contains('nav-open')) {
                closeMenu();
                toggle.focus();
              }
            });

            document.addEventListener('pointerdown', function (e) {
              if (!nav.contains(e.target) && links.classList.contains('nav-open')) {
                closeMenu();
              }
            });
          })();
        </script>
      </Fragment>
    )}

    <main class={`content content--${layout}`} id="main-content" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Dangerous Robot is a research project sponsored by <a href="https://treadlightly.ai">TreadLightly AI</a>
      </p>
      <p>
        <a href="/values">Values</a>
        &nbsp;·&nbsp;
        <a href="/research#methodology">Methodology</a>
        &nbsp;·&nbsp;
        <a href="/credits">Credits</a>
      </p>
      <p>
        <a href="https://github.com/dangerous-robot/site" target="_blank" rel="noopener noreferrer">GitHub</a>
        &nbsp;·&nbsp;
        <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener noreferrer">CC-BY-4.0</a>
        &nbsp;·&nbsp;
        v{siteVersion}
      </p>
    </footer>

    <A11yControl />

    <style>
      .alpha-banner {
        background: var(--color-accent);
        color: var(--color-bg);
        padding: var(--space-xs) var(--space-lg);
        font-family: var(--font-mono);
        font-size: var(--font-size-2xs);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        text-align: center;
        display: flex;
        gap: var(--space-sm);
        justify-content: center;
        align-items: baseline;
        flex-wrap: nowrap;
        white-space: nowrap;
        overflow: hidden;
      }

      .alpha-tag {
        font-weight: 700;
        letter-spacing: 0.18em;
        margin-inline-end: var(--space-xs);
        flex-shrink: 0;
      }

      .alpha-banner a {
        color: inherit;
        text-decoration: underline;
      }

      .alpha-banner a:hover {
        text-decoration: none;
      }

      @media (max-width: 880px) {
        .alpha-banner > a {
          display: none;
        }
      }

      .site-nav {
        border-bottom: 1px solid var(--color-border);
        padding: var(--space-md) 0;
        background: var(--color-surface);
      }

      .nav-inner {
        padding: 0 var(--space-lg);
        display: flex;
        align-items: center;
        gap: var(--space-md);
      }

      .site-name-group {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-shrink: 0;
      }

      .site-name {
        font-family: var(--font-wordmark);
        font-size: 1.15rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        color: var(--color-site-name);
        text-decoration: none;
        display: flex;
        align-items: center;
        white-space: nowrap;
        /* Flair: 2px accent bar on left edge of site name */
        border-left: 2px solid var(--color-accent);
        padding-left: 0.5rem;
      }

      .site-logo {
        height: 34px;
        width: 34px;
        object-fit: contain;
        /* Visual size +44% (1.2 × 1.2), layout box unchanged */
        transform: scale(1.44);
        transform-origin: center;
        margin: 0 1em;
        opacity: 0.72;
      }

      :global([data-theme="dark"]) .site-logo {
        filter: invert(1) brightness(0.85);
        opacity: 0.72;
      }

      .site-name:hover {
        text-decoration: none;
        color: var(--color-text);
      }

      /* Wrapper: fills remaining nav space, contains top-links (centered) + sub-links (right) */
      .nav-links {
        flex: 1;
        display: flex;
        align-items: center;
        gap: var(--space-sm);
      }

      /* Section labels centered within their available space */
      .nav-top-links {
        flex: 1;
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
        gap: var(--space-lg);
      }

      /* Sub-links right-aligned with a border separator */
      .nav-sub-links {
        flex-shrink: 0;
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        gap: var(--space-lg);
        border-left: 1px solid var(--color-border);
        padding-left: var(--space-md);
      }

      /* Option C full-menu dropdown: hidden in horizontal mode */
      .nav-dropdown-sections {
        display: none;
      }

      .nav-links a {
        color: var(--color-nav-link);
        font-size: var(--font-size-sm);
        text-decoration: none;
      }

      /* Section labels (Research, Resources) — bigger and stronger than sub-links */
      .nav-section-item a {
        color: var(--color-nav-link);
        font-size: 1.05rem;
        font-weight: 600;
      }

      .nav-links a:hover {
        color: var(--color-nav-link-hover);
        text-decoration: none;
      }

      .nav-links a:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 3px;
        border-radius: 2px;
      }

      /* Active page: underline marks exact location */
      .nav-links a[aria-current="page"] {
        color: var(--color-nav-link-hover);
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      /* Active section chip: persistent eyebrow, same look on section root and subpages */
      .nav-section-item a[aria-current] {
        color: var(--color-accent);
        background: color-mix(in srgb, var(--color-accent) 10%, transparent);
        padding: 0.1em 0.45em;
        border-radius: var(--radius-sm);
        border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
        text-decoration: none;
      }

      /* Skip-to-main link: visually hidden until focused */
      .skip-nav {
        position: absolute;
        left: -9999px;
        z-index: 200;
        padding: var(--space-sm) var(--space-lg);
        background: var(--color-accent);
        color: var(--color-surface);
        font-size: var(--font-size-sm);
        font-family: var(--font-mono);
        text-decoration: none;
        border-radius: 0 0 var(--radius-sm) 0;
      }

      .skip-nav:focus {
        left: 0;
        top: 0;
      }

      .content {
        max-width: var(--content-max-width);
        margin: 0 auto;
        padding: var(--space-xl) var(--space-lg);
      }

      .content--wide {
        max-width: var(--content-max-width-wide, 72rem);
      }

      .content--reading {
        max-width: var(--content-max-width-reading, var(--content-max-width));
      }

      .content--bare {
        max-width: none;
        padding: 0;
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        padding: var(--space-md) 0;
        text-align: center;
        color: var(--color-footer-text);
        font-family: var(--font-mono);
        font-size: var(--font-size-2xs);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        line-height: 1.4;
      }

      .site-footer p {
        margin: var(--space-xs) 0;
      }

      .site-footer a {
        color: var(--color-footer-link);
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .site-footer a:hover {
        color: var(--color-footer-link-hover);
        text-decoration: underline;
      }

      /* Toggle button: hidden by default, shown when JS detects overflow */
      .nav-toggle {
        display: none;
        align-items: center;
        background: none;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        color: var(--color-nav-link);
        padding: var(--space-xs) var(--space-sm);
        cursor: pointer;
        flex-shrink: 0;
        line-height: 1;
        margin-left: auto;
      }

      .nav-toggle:hover {
        color: var(--color-nav-link-hover);
        border-color: var(--color-nav-link-hover);
      }

      .nav-toggle:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
      }

      /* Collapsed state: JS adds nav--collapsed when links would overflow wordmark */
      .site-nav.nav--collapsed {
        position: relative;
      }

      .site-nav.nav--collapsed .nav-toggle {
        display: flex;
      }

      .site-nav.nav--collapsed .site-logo {
        margin: 0 var(--space-sm);
      }

      .site-nav.nav--collapsed .nav-links {
        display: none;
        flex-direction: column;
        gap: 0;
        position: absolute;
        top: 100%;
        left: auto;
        right: 0;
        min-width: 14rem;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-top: none;
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.35);
        padding: var(--space-sm) var(--space-xl) var(--space-lg);
        z-index: 100;
      }

      .site-nav.nav--collapsed .nav-links.nav-open {
        display: flex;
      }

      /* Stack the two lists vertically in the dropdown */
      .site-nav.nav--collapsed .nav-top-links,
      .site-nav.nav--collapsed .nav-sub-links {
        flex-direction: column;
        justify-content: flex-start;
        border-left: none;
        padding-left: 0;
        gap: 0;
      }

      /* Each item separated by border; sub-links ul continues the same pattern */
      .site-nav.nav--collapsed .nav-top-links li,
      .site-nav.nav--collapsed .nav-sub-links li {
        border-top: 1px solid var(--color-border);
      }

      .site-nav.nav--collapsed .nav-links a {
        display: block;
        padding: var(--space-md) 0;
        font-size: 1.05rem;
      }

      .site-nav.nav--collapsed .nav-section-item a {
        font-size: 1.15rem;
        font-weight: 700;
      }

      /* Chip doesn't work as a block element — reset in dropdown */
      .site-nav.nav--collapsed .nav-section-item a[aria-current] {
        background: none;
        border: none;
        padding-left: 0;
        padding-right: 0;
        border-radius: 0;
      }

      /* Option C full menu: swap in when collapsed/open, hide horizontal elements */
      .site-nav.nav--collapsed .nav-links.nav-open .nav-top-links,
      .site-nav.nav--collapsed .nav-links.nav-open .nav-sub-links {
        display: none;
      }

      .site-nav.nav--collapsed .nav-links.nav-open .nav-dropdown-sections {
        display: flex;
        flex-direction: column;
        width: 100%;
      }

      .site-nav.nav--collapsed .nav-dropdown-sections .dropdown-section-label {
        display: block;
        padding: var(--space-md) 0;
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--color-nav-link-hover);
        text-decoration: none;
        border-top: 1px solid var(--color-border);
      }

      .site-nav.nav--collapsed .nav-dropdown-sections .dropdown-section-label[aria-current] {
        color: var(--color-accent);
      }

      .site-nav.nav--collapsed .nav-dropdown-sections .dropdown-section-links {
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .site-nav.nav--collapsed .nav-dropdown-sections .dropdown-section-links li {
        border-top: 1px solid var(--color-border);
      }

      .site-nav.nav--collapsed .nav-dropdown-sections .dropdown-section-links a {
        display: block;
        padding: var(--space-sm) 0 var(--space-sm) var(--space-lg);
        font-size: var(--font-size-sm);
        color: var(--color-nav-link);
        text-decoration: none;
      }

      .site-nav.nav--collapsed .nav-dropdown-sections .dropdown-section-links a[aria-current="page"] {
        color: var(--color-nav-link-hover);
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      /* Reduce padding on narrow viewports regardless of collapse state */
      @media (max-width: 540px) {
        .nav-inner,
        .content {
          padding-left: var(--space-md);
          padding-right: var(--space-md);
        }
      }
    </style>
  </body>
</html>
