---
import { ExternalLink } from 'lucide-astro';
import InlineMd from './InlineMd.astro';

interface Summary {
  ai_ethics: string;
  financial_transparency: string;
  environmental: string;
  notes: string;
}

interface Product {
  key: string;
  name: string;
  url: string;
  status: 'active' | 'excluded';
  summary?: Summary;
}

interface SummaryData {
  products: Product[];
}

interface Props {
  data: SummaryData;
}

const { data } = Astro.props;
const activeProducts = (data.products ?? []).filter((p) => p.status === 'active');

const columns: { key: keyof Summary; label: string }[] = [
  { key: 'ai_ethics', label: 'AI ethics' },
  { key: 'financial_transparency', label: 'Financial transparency' },
  { key: 'environmental', label: 'Environmental' },
  { key: 'notes', label: 'Notes' },
];
---
<div class="responsible-summary">
  <table class="summary-table">
    <caption class="sr-only">
      Quick-glance summary of each product's stance on AI ethics, financial
      transparency, environmental impact, and other notes.
    </caption>
    <thead>
      <tr>
        <th scope="col">Product</th>
        {columns.map((col) => (
          <th scope="col">{col.label}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {activeProducts.map((product) => (
        <tr>
          <th scope="row" data-label="Product" class="product-cell">
            <a href={product.url} target="_blank" rel="noopener noreferrer">
              {product.name}
              <ExternalLink size={12} aria-hidden="true" />
            </a>
          </th>
          {columns.map((col) => (
            <td data-label={col.label}>
              <InlineMd text={product.summary?.[col.key] ?? ''} />
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .responsible-summary {
    color: var(--color-text);
    margin: 0 0 var(--space-2xl);
  }

  .summary-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }

  .summary-table th,
  .summary-table td {
    padding: 0.6rem 0.75rem;
    vertical-align: top;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
    line-height: var(--line-height-body);
  }

  .summary-table thead th {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--color-text-heading);
    border-bottom: 1px solid var(--color-border);
  }

  .summary-table tbody th {
    font-weight: 600;
    color: var(--color-text-heading);
    white-space: nowrap;
  }

  .product-cell a {
    color: var(--color-text-heading);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
  }

  .product-cell a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .product-cell :global(svg) {
    color: var(--color-text-faint);
  }

  .summary-table td :global(a) {
    color: var(--color-accent);
  }

  /* High-contrast: links underlined always, stronger separator. */
  :global([data-contrast="high"]) .product-cell a,
  :global([data-contrast="high"]) .summary-table td :global(a) {
    text-decoration: underline;
  }

  :global([data-contrast="high"]) .summary-table th,
  :global([data-contrast="high"]) .summary-table td {
    border-bottom-width: 2px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /*
   * Mobile: collapse to one definition-list-style stack per row, no markup
   * duplication. The <table> remains the single source of truth; CSS resets
   * table semantics visually and surfaces the column label from data-label
   * via ::before, so each cell reads as "Label: value".
   */
  @media (max-width: 640px) {
    .summary-table,
    .summary-table thead,
    .summary-table tbody,
    .summary-table tr,
    .summary-table th,
    .summary-table td {
      display: block;
      width: 100%;
    }

    .summary-table thead {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    .summary-table tr {
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      padding: var(--space-sm) var(--space-md);
      margin-bottom: var(--space-md);
    }

    .summary-table th,
    .summary-table td {
      border-bottom: none;
      padding: var(--space-xs) 0;
      white-space: normal;
    }

    .summary-table tbody th.product-cell {
      font-size: 1.05rem;
      font-family: var(--font-heading);
      padding-bottom: var(--space-sm);
      border-bottom: 1px solid var(--color-border);
      margin-bottom: var(--space-xs);
    }

    .summary-table td::before {
      content: attr(data-label);
      display: block;
      font-size: var(--font-size-xs);
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 0.15rem;
    }
  }
</style>
