---
export type WallpaperVariant = 'default' | 'ai-safety' | 'responsible-ai' | 'none';

interface Props {
  variant?: WallpaperVariant;
}

const { variant = 'default' } = Astro.props;

type Asset = { src: string; format: 'svg' | 'raster' };
const ASSETS: Record<Exclude<WallpaperVariant, 'none'>, Asset> = {
  default: { src: '/resources/wallpapers/default.svg', format: 'svg' },
  'ai-safety': { src: '/resources/wallpapers/ai-safety.svg', format: 'svg' },
  'responsible-ai': { src: '/resources/wallpapers/responsible-ai.png', format: 'raster' },
};

const asset = variant === 'none' ? null : ASSETS[variant];
---
{asset && (
  <div class={`resources-wallpaper is-${asset.format}`} aria-hidden="true">
    <img src={asset.src} alt="" decoding="async" fetchpriority="low" />
  </div>
)}
