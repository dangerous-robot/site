---
interface Props { size?: number; }
const { size = 18 } = Astro.props;
---
<svg
  class="disclosure-indicator"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  <circle cx="12" cy="12" r="10" />
  <path d="M8 12h8" />
  <path class="v-stroke" d="M12 8v8" />
</svg>
<style is:global>
  /* Global so host components can target [aria-expanded="true"] / [open]
     ancestors without :global() wrappers. The v-stroke hide rule also
     needs to be global: the .v-stroke element is rendered by this
     component, so a scoped rule in the host wouldn't match it. */
  .disclosure-indicator { flex-shrink: 0; }
  [aria-expanded="true"] .v-stroke,
  [open] .v-stroke { display: none; }
</style>
