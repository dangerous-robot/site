---
interface Props { size?: number; }
const { size = 18 } = Astro.props;
---
<svg
  class="disclosure-indicator"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
>
  <circle cx="12" cy="12" r="10" />
  <path d="M8 12h8" />
  <path class="v-stroke" d="M12 8v8" />
</svg>
<style is:global>
  /* Class is global so host-component CSS can target [aria-expanded="true"] /
     [open] ancestors without needing :global() wrappers. */
  .disclosure-indicator { flex-shrink: 0; }
</style>
