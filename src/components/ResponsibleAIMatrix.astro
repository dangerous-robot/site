---
import { Check, X, Minus, HelpCircle, ArrowUp, ExternalLink } from 'lucide-astro';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';

type CellType =
  | 'yes'
  | 'no'
  | 'no-good'
  | 'partial'
  | 'planned'
  | 'text'
  | 'unknown'
  | 'na';

const ICONS: Record<
  Exclude<CellType, 'text' | 'na'>,
  { Icon: AstroComponentFactory; srLabel: string }
> = {
  yes: { Icon: Check, srLabel: 'Yes' },
  no: { Icon: X, srLabel: 'No' },
  'no-good': { Icon: X, srLabel: 'No (negative)' },
  partial: { Icon: Minus, srLabel: 'Partial' },
  planned: { Icon: ArrowUp, srLabel: 'Planned' },
  unknown: { Icon: HelpCircle, srLabel: 'Unknown' },
};

interface Cell {
  type: CellType;
  detail?: string;
  footnote?: string;
}

interface Product {
  key: string;
  name: string;
  url: string;
  status: 'active' | 'excluded';
  excluded_reason?: string;
}

interface Group {
  key: string;
  label: string;
}

interface Feature {
  key: string;
  label: string;
  group: string;
  cells: Record<string, Cell>;
}

interface Footnote {
  subject: string;
  text: string;
}

interface MatrixData {
  lede?: string;
  caption?: string;
  groups: Group[];
  products: Product[];
  features: Feature[];
  footnotes?: Footnote[];
}

interface Props {
  data: MatrixData;
}

const { data } = Astro.props;
const groups = data.groups ?? [];
const activeProducts = (data.products ?? []).filter((p) => p.status === 'active');
const features = data.features ?? [];
const footnotes = data.footnotes ?? [];

const featuresByGroup = new Map<string, Feature[]>();
for (const group of groups) featuresByGroup.set(group.key, []);
for (const feature of features) {
  const bucket = featuresByGroup.get(feature.group);
  if (bucket) bucket.push(feature);
}
---
<div class="responsible-matrix">
  {data.lede && <p class="lede">{data.lede}</p>}

  <section id="chatbots" class="matrix-section">
    <h2>
      Chatbots
      <a href="#top" class="return-top" aria-label="Return to top">
        <ArrowUp size={14} aria-hidden="true" />
      </a>
    </h2>

    <div class="table-scroll">
      <table class="matrix-table">
        <thead>
          <tr>
            <th scope="col" class="dim-col">
              <span class="sr-only">Feature</span>
            </th>
            {activeProducts.map((p) => (
              <th scope="col" class="product-col" data-product-key={p.key}>
                <a href={p.url} target="_blank" rel="noopener noreferrer">
                  {p.name}
                  <ExternalLink size={12} aria-hidden="true" />
                </a>
              </th>
            ))}
          </tr>
        </thead>
        {groups.map((group) => {
          const rows = featuresByGroup.get(group.key) ?? [];
          if (rows.length === 0) return null;
          return (
            <tbody data-group={group.key}>
              <tr class="ra-group-header">
                <th colspan={1 + activeProducts.length} scope="rowgroup">
                  {group.label}
                </th>
              </tr>
              {rows.map((feature) => (
                <tr>
                  <th scope="row" class="dim-label">{feature.label}</th>
                  {activeProducts.map((p) => {
                    const cell = feature.cells?.[p.key] ?? { type: 'na' as CellType };
                    const icon = cell.type in ICONS ? ICONS[cell.type as keyof typeof ICONS] : null;
                    return (
                      <td class={`cell cell--${cell.type}`} data-product-key={p.key}>
                        {icon && (
                          <span class="cell-inline">
                            <icon.Icon size={16} aria-hidden="true" />
                            <span class="sr-only">{icon.srLabel}</span>
                            {cell.detail && <span class="detail">{cell.detail}</span>}
                          </span>
                        )}
                        {cell.type === 'text' && (
                          <span class="detail">{cell.detail}</span>
                        )}
                        {cell.type === 'na' && (
                          <span class="na" aria-label="Not applicable">&ndash;</span>
                        )}
                      </td>
                    );
                  })}
                </tr>
              ))}
            </tbody>
          );
        })}
      </table>
    </div>

    {data.caption && <p class="caption">{data.caption}</p>}

    {footnotes.length > 0 && (
      <details class="resources-details">
        <summary>[+] Sources and context</summary>
        <ol class="footnotes">
          {footnotes.map((note) => (
            <li>
              <strong>{note.subject}:</strong> {note.text}
            </li>
          ))}
        </ol>
      </details>
    )}
  </section>
</div>

<style>
  .responsible-matrix {
    color: var(--color-text);
  }

  .lede {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-xl);
    max-width: 36rem;
  }

  .matrix-section {
    scroll-margin-top: 5rem;
  }

  .matrix-section h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-text-heading);
    margin: 0 0 var(--space-md);
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .return-top {
    color: var(--color-text-faint);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .return-top:hover { color: var(--color-accent); }

  .table-scroll {
    overflow-x: auto;
    margin: 0 calc(-1 * var(--space-md));
    padding: 0 var(--space-md);
  }

  .matrix-table {
    width: 100%;
    min-width: 44rem;
    border-collapse: collapse;
    font-size: var(--font-size-sm);
  }

  .matrix-table th,
  .matrix-table td {
    padding: 0.6rem 0.75rem;
    vertical-align: top;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .matrix-table thead th {
    border-bottom: 1px solid var(--color-border);
  }

  .dim-col {
    width: 14rem;
  }

  .product-col {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .product-col a {
    color: var(--color-text-heading);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
  }

  .product-col a:hover { color: var(--color-accent); }

  .dim-label {
    font-weight: 400;
    color: var(--color-text-heading);
  }

  .ra-group-header th {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--font-size-sm);
    color: var(--color-text-heading);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding-top: var(--space-md);
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .cell {
    color: var(--color-text);
  }

  .cell-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .detail {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .cell--yes :global(svg) {
    color: var(--color-verdict-true);
    flex-shrink: 0;
  }

  .cell--no :global(svg) {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .cell--no-good :global(svg) {
    color: var(--color-verdict-false);
    flex-shrink: 0;
  }

  .cell--partial :global(svg) {
    color: var(--color-verdict-mixed);
    flex-shrink: 0;
  }

  .cell--planned :global(svg) {
    color: var(--color-kind-report);
    flex-shrink: 0;
  }

  .cell--unknown :global(svg) {
    color: var(--color-text-faint);
    flex-shrink: 0;
  }

  .na {
    color: var(--color-text-faint);
  }

  .product-col :global(svg) {
    color: var(--color-text-faint);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .caption {
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    margin: var(--space-md) 0 var(--space-xl);
  }

  .resources-details {
    margin-top: var(--space-xl);
  }

  .footnotes {
    margin: var(--space-md) 0 0;
    padding-left: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footnotes li {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    line-height: 1.55;
  }

  .footnotes strong {
    color: var(--color-text-heading);
  }
</style>
