---
import { Check, X, Minus, HelpCircle, ArrowUp, ExternalLink } from 'lucide-astro';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';
import ResponsibleAIFilters from './ResponsibleAIFilters.astro';

type CellType =
  | 'yes'
  | 'no'
  | 'no-good'
  | 'partial'
  | 'planned'
  | 'text'
  | 'unknown'
  | 'na';

const ICONS: Record<
  Exclude<CellType, 'text' | 'na'>,
  { Icon: AstroComponentFactory; srLabel: string }
> = {
  yes: { Icon: Check, srLabel: 'Yes' },
  no: { Icon: X, srLabel: 'No' },
  'no-good': { Icon: X, srLabel: 'No (negative)' },
  partial: { Icon: Minus, srLabel: 'Partial' },
  planned: { Icon: ArrowUp, srLabel: 'Planned' },
  unknown: { Icon: HelpCircle, srLabel: 'Unknown' },
};

interface Cell {
  type: CellType;
  detail?: string;
  footnote?: string;
}

interface Product {
  key: string;
  name: string;
  url: string;
  status: 'active' | 'excluded';
  excluded_reason?: string;
}

interface Group {
  key: string;
  label: string;
}

interface Ideal {
  value: CellType;
  note?: string;
}

interface Feature {
  key: string;
  label: string;
  group: string;
  ideal?: Ideal;
  cells: Record<string, Cell>;
}

interface MatrixData {
  lede?: string;
  caption?: string;
  groups: Group[];
  products: Product[];
  features: Feature[];
}

interface Props {
  data: MatrixData;
}

const { data } = Astro.props;
const groups = data.groups ?? [];
const activeProducts = (data.products ?? []).filter((p) => p.status === 'active');
const features = data.features ?? [];

const featuresByGroup = new Map<string, Feature[]>();
for (const group of groups) featuresByGroup.set(group.key, []);
for (const feature of features) {
  const bucket = featuresByGroup.get(feature.group);
  if (bucket) bucket.push(feature);
}
---
<div class="responsible-matrix">
  {data.lede && <p class="lede">{data.lede}</p>}

  <section id="chatbots" class="ra-matrix matrix-section">
    <h2>
      Chatbots
      <a href="#top" class="return-top" aria-label="Return to top">
        <ArrowUp size={14} aria-hidden="true" />
      </a>
    </h2>

    <ResponsibleAIFilters products={activeProducts} groups={groups} />

    <div class="ra-matrix__scroll" role="region" aria-label="Feature comparison matrix" tabindex="0">
      <table class="matrix-table">
        <thead>
          <tr>
            <th scope="col" class="dim-col ra-feature-head">
              <span class="sr-only">Feature</span>
            </th>
            <th scope="col" class="ra-ideal-col ra-ideal-head">
              Ideal<sup><a href="#fn-editorial-pick" aria-label="Editorial pick footnote">*</a></sup>
            </th>
            {activeProducts.map((p) => (
              <th scope="col" class="product-col" data-product-key={p.key}>
                <button
                  type="button"
                  class="ra-col-toggle"
                  aria-pressed="false"
                  data-filter-product={p.key}
                >{p.name}</button>
                <a
                  href={p.url}
                  class="ra-product-link"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Visit ${p.name} site`}
                >
                  <ExternalLink size={12} aria-hidden="true" />
                </a>
              </th>
            ))}
          </tr>
        </thead>
        {groups.map((group) => {
          const rows = featuresByGroup.get(group.key) ?? [];
          if (rows.length === 0) return null;
          return (
            <tbody data-group={group.key} id={`ra-group-${group.key}`}>
              <tr class="ra-group-header">
                <th colspan={2 + activeProducts.length} scope="rowgroup">
                  <button
                    type="button"
                    class="ra-group-toggle"
                    aria-expanded="true"
                    aria-controls={`ra-group-${group.key}`}
                    data-filter-group-collapse={group.key}
                  >{group.label}</button>
                </th>
              </tr>
              {rows.map((feature) => {
                const idealIcon = feature.ideal && feature.ideal.value in ICONS
                  ? ICONS[feature.ideal.value as keyof typeof ICONS]
                  : null;
                return (
                <tr>
                  <th scope="row" class="dim-label">{feature.label}</th>
                  <td class={`cell ra-ideal-cell${feature.ideal ? ` cell--${feature.ideal.value}` : ''}`}>
                    {feature.ideal && idealIcon ? (
                      feature.ideal.note ? (
                        <details class="ra-ideal-note">
                          <summary>
                            <span class="cell-inline">
                              <idealIcon.Icon size={16} aria-hidden="true" />
                              <span class="sr-only">{idealIcon.srLabel}</span>
                            </span>
                          </summary>
                          <span class="detail">{feature.ideal.note}</span>
                        </details>
                      ) : (
                        <span class="cell-inline">
                          <idealIcon.Icon size={16} aria-hidden="true" />
                          <span class="sr-only">{idealIcon.srLabel}</span>
                        </span>
                      )
                    ) : (
                      <span class="sr-only">no editorial pick</span>
                    )}
                  </td>
                  {activeProducts.map((p) => {
                    const cell = feature.cells?.[p.key] ?? { type: 'na' as CellType };
                    const icon = cell.type in ICONS ? ICONS[cell.type as keyof typeof ICONS] : null;
                    return (
                      <td class={`cell cell--${cell.type}`} data-product-key={p.key}>
                        {icon && (
                          <span class="cell-inline">
                            <icon.Icon size={16} aria-hidden="true" />
                            <span class="sr-only">{icon.srLabel}</span>
                            {cell.detail && <span class="detail">{cell.detail}</span>}
                          </span>
                        )}
                        {cell.type === 'text' && (
                          <span class="detail">{cell.detail}</span>
                        )}
                        {cell.type === 'na' && (
                          <span class="na" aria-label="Not applicable">&ndash;</span>
                        )}
                      </td>
                    );
                  })}
                </tr>
                );
              })}
            </tbody>
          );
        })}
      </table>
    </div>

    {data.caption && <p class="caption">{data.caption}</p>}
  </section>
</div>

<script>
  function initMatrix(root: HTMLElement) {
    const readSet = (attr: string) => {
      const v = root.getAttribute(attr);
      return new Set(v ? v.split(/\s+/).filter(Boolean) : []);
    };
    const writeSet = (attr: string, set: Set<string>) => {
      if (set.size === 0) root.removeAttribute(attr);
      else root.setAttribute(attr, [...set].join(' '));
    };
    const syncProducts = () => {
      const hidden = readSet('data-hidden-product');
      root.querySelectorAll<HTMLButtonElement>('[data-filter-product]').forEach((el) => {
        el.setAttribute('aria-pressed', hidden.has(el.dataset.filterProduct!) ? 'true' : 'false');
      });
    };
    const syncGroups = () => {
      const hidden = readSet('data-hidden-group');
      root.querySelectorAll<HTMLButtonElement>('[data-filter-group]').forEach((el) => {
        el.setAttribute('aria-pressed', hidden.has(el.dataset.filterGroup!) ? 'true' : 'false');
      });
    };
    const allProductKeys = () =>
      [...root.querySelectorAll<HTMLElement>('th[data-product-key]')].map((el) => el.dataset.productKey!);
    const allGroupKeys = () =>
      [...root.querySelectorAll<HTMLElement>('tbody[data-group]')].map((el) => el.dataset.group!);
    root.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (!btn || !root.contains(btn)) return;
      const d = btn.dataset;
      if (d.filterProduct) {
        const s = readSet('data-hidden-product');
        s.has(d.filterProduct) ? s.delete(d.filterProduct) : s.add(d.filterProduct);
        writeSet('data-hidden-product', s);
        syncProducts();
      } else if (d.filterGroup) {
        const s = readSet('data-hidden-group');
        s.has(d.filterGroup) ? s.delete(d.filterGroup) : s.add(d.filterGroup);
        writeSet('data-hidden-group', s);
        syncGroups();
      } else if (d.filterOnlyProduct) {
        writeSet('data-hidden-product', new Set(allProductKeys().filter((k) => k !== d.filterOnlyProduct)));
        syncProducts();
      } else if (d.filterOnlyGroup) {
        writeSet('data-hidden-group', new Set(allGroupKeys().filter((k) => k !== d.filterOnlyGroup)));
        syncGroups();
      } else if (d.filterGroupCollapse) {
        const tbody = root.querySelector<HTMLElement>(`tbody[data-group="${d.filterGroupCollapse}"]`);
        if (!tbody) return;
        const collapsed = tbody.hasAttribute('data-collapsed');
        collapsed ? tbody.removeAttribute('data-collapsed') : tbody.setAttribute('data-collapsed', '');
        btn.setAttribute('aria-expanded', collapsed ? 'true' : 'false');
      } else if (d.filterReset !== undefined) {
        root.removeAttribute('data-hidden-product');
        root.removeAttribute('data-hidden-group');
        root.querySelectorAll('tbody[data-collapsed]').forEach((el) => el.removeAttribute('data-collapsed'));
        root.querySelectorAll<HTMLButtonElement>('[data-filter-group-collapse]').forEach((el) =>
          el.setAttribute('aria-expanded', 'true'));
        syncProducts();
        syncGroups();
      }
    });
  }
  document.querySelectorAll<HTMLElement>('.ra-matrix').forEach(initMatrix);
</script>

<style>
  .responsible-matrix {
    color: var(--color-text);
  }

  .lede {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-xl);
    max-width: 36rem;
  }

  .ra-matrix {
    --ra-feature-col-width: 14rem;
    --ra-ideal-col-width: 5rem;
    scroll-margin-top: 5rem;
  }

  .matrix-section h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-text-heading);
    margin: 0 0 var(--space-md);
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .return-top {
    color: var(--color-text-faint);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .return-top:hover { color: var(--color-accent); }

  .ra-matrix__scroll {
    overflow-x: auto;
    margin: 0 calc(-1 * var(--space-md));
    padding: 0 var(--space-md);
  }

  .matrix-table {
    width: 100%;
    min-width: 44rem;
    border-collapse: separate;
    border-spacing: 0;
    font-size: var(--font-size-sm);
  }

  .matrix-table th,
  .matrix-table td {
    padding: 0.6rem 0.75rem;
    vertical-align: top;
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  /* sticky thead */
  .matrix-table thead th {
    position: sticky;
    top: 0;
    z-index: 2;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  /* sticky-left feature column */
  .matrix-table tbody th[scope="row"] {
    position: sticky;
    left: 0;
    z-index: 2;
    background: var(--color-bg);
    border-right: 1px solid var(--color-border);
  }

  [data-contrast="high"] .matrix-table tbody th[scope="row"] {
    border-right-width: 2px;
  }

  /* top-left intersection */
  .matrix-table thead .dim-col,
  .matrix-table thead .ra-feature-head {
    left: 0;
    z-index: 3;
    border-right: 1px solid var(--color-border);
  }

  .dim-col {
    width: var(--ra-feature-col-width);
    min-width: var(--ra-feature-col-width);
  }

  .matrix-table tbody th[scope="row"] {
    width: var(--ra-feature-col-width);
    min-width: var(--ra-feature-col-width);
  }

  /* Ideal column: sticky-left, faint tint, sits between Feature and products */
  .matrix-table .ra-ideal-col,
  .matrix-table .ra-ideal-cell {
    position: sticky;
    left: var(--ra-feature-col-width);
    z-index: 2;
    width: var(--ra-ideal-col-width);
    min-width: var(--ra-ideal-col-width);
    background: var(--color-surface);
    border-right: 1px solid var(--color-border);
  }

  .matrix-table thead .ra-ideal-head {
    top: 0;
    z-index: 3;
  }

  .ra-ideal-head sup {
    font-size: 0.7em;
    line-height: 0;
    margin-left: 0.1em;
  }

  .ra-ideal-head sup a {
    color: var(--color-text-faint);
    text-decoration: none;
  }

  .ra-ideal-head sup a:hover { color: var(--color-accent); }

  .ra-ideal-note {
    display: inline-block;
  }

  .ra-ideal-note > summary {
    list-style: none;
    display: inline-block;
    cursor: pointer;
  }

  .ra-ideal-note > summary::-webkit-details-marker {
    display: none;
  }

  .ra-ideal-note[open] > summary {
    margin-bottom: 0.25rem;
  }

  /* High-contrast: drop the tint, delimit with borders instead */
  [data-contrast="high"] .matrix-table .ra-ideal-col,
  [data-contrast="high"] .matrix-table .ra-ideal-cell {
    background: var(--color-bg);
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
  }

  .product-col {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .ra-col-toggle {
    font: inherit;
    color: var(--color-text-heading);
    background: transparent;
    border: 1px solid transparent;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    cursor: pointer;
  }

  .ra-col-toggle[aria-pressed="true"] {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .ra-product-link {
    color: var(--color-text-faint);
    display: inline-flex;
    align-items: center;
    margin-left: 0.3em;
  }

  .ra-product-link:hover { color: var(--color-accent); }

  .dim-label {
    font-weight: 400;
    color: var(--color-text-heading);
  }

  /* group header row: not sticky */
  .ra-group-header th {
    position: static;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--font-size-sm);
    color: var(--color-text-heading);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding-top: var(--space-md);
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .ra-group-toggle {
    font: inherit;
    color: inherit;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    text-transform: inherit;
    letter-spacing: inherit;
  }

  .cell {
    color: var(--color-text);
    max-width: 12rem;
    word-break: break-word;
  }

  .cell-inline {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .detail {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .cell--yes :global(svg) { color: var(--color-verdict-true); flex-shrink: 0; }
  .cell--no :global(svg) { color: var(--color-text-muted); flex-shrink: 0; }
  .cell--no-good :global(svg) { color: var(--color-verdict-false); flex-shrink: 0; }
  .cell--partial :global(svg) { color: var(--color-verdict-mixed); flex-shrink: 0; }
  .cell--planned :global(svg) { color: var(--color-kind-report); flex-shrink: 0; }
  .cell--unknown :global(svg) { color: var(--color-text-faint); flex-shrink: 0; }

  .na {
    color: var(--color-text-faint);
  }

  /* collapse: hide all non-header rows when [data-collapsed] */
  .matrix-table tbody[data-collapsed] > tr:not(.ra-group-header) {
    display: none;
  }

  .product-col :global(svg) {
    color: var(--color-text-faint);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .caption {
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    margin: var(--space-md) 0 var(--space-xl);
  }

</style>

<style is:global set:html={`
${activeProducts.map((p) => `
  .ra-matrix[data-hidden-product~="${p.key}"] [data-product-key="${p.key}"] { display: none; }
`).join('')}
${groups.map((g) => `
  .ra-matrix[data-hidden-group~="${g.key}"] tbody[data-group="${g.key}"] { display: none; }
`).join('')}
`} />
