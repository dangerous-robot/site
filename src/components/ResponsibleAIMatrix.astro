---
import { Check, X, Minus, HelpCircle, ArrowUp, ExternalLink } from 'lucide-astro';
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';
import ResponsibleAIFilters from './ResponsibleAIFilters.astro';

type CellType =
  | 'yes'
  | 'no'
  | 'no-good'
  | 'partial'
  | 'planned'
  | 'text'
  | 'unknown'
  | 'na';

const ICONS: Record<
  Exclude<CellType, 'text' | 'na'>,
  { Icon: AstroComponentFactory; srLabel: string }
> = {
  yes: { Icon: Check, srLabel: 'Yes' },
  no: { Icon: X, srLabel: 'No' },
  'no-good': { Icon: X, srLabel: 'No (negative)' },
  partial: { Icon: Minus, srLabel: 'Partial' },
  planned: { Icon: ArrowUp, srLabel: 'Planned' },
  unknown: { Icon: HelpCircle, srLabel: 'Unknown' },
};

interface Cell {
  type: CellType;
  detail?: string;
  footnote?: string;
}

function renderDetail(s: string): string {
  const esc = s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
  return esc.replace(
    /\[([^\]]+)\]\(([^)\s]+)\)/g,
    (_m, text, url) =>
      `<a href="${url}" target="_blank" rel="noopener noreferrer">${text}</a>`,
  );
}

interface Product {
  key: string;
  name: string;
  url: string;
  status: 'active' | 'excluded';
  excluded_reason?: string;
  initially_hidden?: boolean;
}

interface Group {
  key: string;
  label: string;
}

interface Ideal {
  value: CellType;
  note?: string;
}

interface Feature {
  key: string;
  label: string;
  group: string;
  ideal?: Ideal;
  cells: Record<string, Cell>;
}

interface MatrixData {
  lede?: string;
  caption?: string;
  groups: Group[];
  products: Product[];
  features: Feature[];
}

interface Props {
  data: MatrixData;
  lastModified?: Date;
}

const { data, lastModified } = Astro.props;

const lastModifiedLabel = lastModified
  ? lastModified.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  : undefined;
const lastModifiedISO = lastModified?.toISOString();
const groups = data.groups ?? [];
const activeProducts = (data.products ?? []).filter((p) => p.status === 'active');
const features = data.features ?? [];

const featuresByGroup = new Map<string, Feature[]>();
for (const group of groups) featuresByGroup.set(group.key, []);
for (const feature of features) {
  const bucket = featuresByGroup.get(feature.group);
  if (bucket) bucket.push(feature);
}

const initialHiddenProducts = activeProducts
  .filter((p) => (p as Product & { initially_hidden?: boolean }).initially_hidden)
  .map((p) => p.key);
const initialHiddenAttr = initialHiddenProducts.join(' ');
---
<div class="responsible-matrix">
  {data.lede && <p class="lede">{data.lede}</p>}

  <section
    id="comparison-table"
    class="ra-matrix matrix-section"
    data-hidden-product={initialHiddenAttr || undefined}
  >
    <h2>
      Comparison table
      <a href="#top" class="return-top" aria-label="Return to top">
        <ArrowUp size={18} aria-hidden="true" />
      </a>
    </h2>

    <ResponsibleAIFilters
      products={activeProducts}
      initiallyHiddenProducts={initialHiddenProducts}
    />

    <p class="landscape-nudge" aria-hidden="true">Rotate to landscape for the full table.</p>

    <div class="ra-matrix__scroll" role="region" aria-label="Feature comparison matrix" tabindex="0">
      <table class="matrix-table">
        <thead>
          <tr>
            <th scope="col" class="dim-col ra-feature-head">
              <span class="sr-only">Feature</span>
            </th>
            {activeProducts.map((p) => (
              <th scope="col" class="product-col" data-product-key={p.key}>
                <a
                  href={p.url}
                  class="ra-product-link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {p.name}
                  <ExternalLink size={12} aria-hidden="true" />
                </a>
              </th>
            ))}
          </tr>
        </thead>
        {groups.map((group) => {
          const rows = featuresByGroup.get(group.key) ?? [];
          if (rows.length === 0) return null;
          return (
            <tbody>
              <tr class="ra-group-header">
                <th colspan={1 + activeProducts.length} scope="rowgroup">
                  <div class="ra-group-sticky">{group.label}</div>
                </th>
              </tr>
              {rows.map((feature) => {
                return (
                <tr>
                  <th scope="row" class="dim-label">{feature.label}</th>
                  {activeProducts.map((p) => {
                    const cell = feature.cells?.[p.key] ?? { type: 'na' as CellType };
                    const icon = cell.type in ICONS ? ICONS[cell.type as keyof typeof ICONS] : null;
                    return (
                      <td class={`cell cell--${cell.type}`} data-product-key={p.key}>
                        {icon && (
                          <span class="cell-inline">
                            <icon.Icon size={18} aria-hidden="true" />
                            <span class="sr-only">{icon.srLabel}</span>
                            {cell.detail && <span class="detail" set:html={renderDetail(cell.detail)} />}
                          </span>
                        )}
                        {cell.type === 'text' && (
                          <span class="detail" set:html={renderDetail(cell.detail ?? '')} />
                        )}
                        {cell.type === 'na' && (
                          <span class="na" aria-label="Not applicable">&ndash;</span>
                        )}
                      </td>
                    );
                  })}
                </tr>
                );
              })}
            </tbody>
          );
        })}
      </table>
    </div>

    <div class="caption-area">
      {data.caption && (
        <p class="caption">
          {data.caption}
          {lastModifiedLabel && (
            <> Last updated: <time datetime={lastModifiedISO}>{lastModifiedLabel}</time>.</>
          )}
        </p>
      )}
      <div class="legend-row">
        <span class="legend-label">Legend:</span>
        <ul class="legend" aria-label="Symbol legend">
          <li class="legend-item legend-item--yes">
            <Check size={14} aria-hidden="true" /><span>Yes</span>
          </li>
          <li class="legend-item legend-item--no">
            <X size={14} aria-hidden="true" /><span>No</span>
          </li>
          <li class="legend-item legend-item--no-good">
            <X size={14} aria-hidden="true" /><span>No <span class="legend-note">(preferred)</span></span>
          </li>
          <li class="legend-item legend-item--partial">
            <Minus size={14} aria-hidden="true" /><span>Partial</span>
          </li>
          <li class="legend-item legend-item--unknown">
            <HelpCircle size={14} aria-hidden="true" /><span>Unknown</span>
          </li>
        </ul>
      </div>
    </div>
  </section>
</div>

<script>
  function initMatrix(root: HTMLElement) {
    const readSet = (attr: string) => {
      const v = root.getAttribute(attr);
      return new Set(v ? v.split(/\s+/).filter(Boolean) : []);
    };
    const writeSet = (attr: string, set: Set<string>) => {
      if (set.size === 0) root.removeAttribute(attr);
      else root.setAttribute(attr, [...set].join(' '));
    };
    // aria-pressed semantics: pressed === SELECTED/VISIBLE (filled chip);
    // not-pressed === hidden (outline chip). The data model still tracks
    // hidden keys, so pressed = !(key in hidden).
    const syncProducts = () => {
      const hidden = readSet('data-hidden-product');
      root.querySelectorAll<HTMLButtonElement>('[data-filter-product]').forEach((el) => {
        el.setAttribute('aria-pressed', hidden.has(el.dataset.filterProduct!) ? 'false' : 'true');
      });
    };
    // Run sync once on init so chips reflect the SSR'd data-hidden-product
    // state (products with initially_hidden start hidden).
    syncProducts();
    root.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button');
      if (!btn || !root.contains(btn)) return;
      const d = btn.dataset;
      if (d.filterProduct) {
        const s = readSet('data-hidden-product');
        s.has(d.filterProduct) ? s.delete(d.filterProduct) : s.add(d.filterProduct);
        writeSet('data-hidden-product', s);
        syncProducts();
      } else if (d.filterReset !== undefined) {
        root.removeAttribute('data-hidden-product');
        syncProducts();
      }
    });
  }
  document.querySelectorAll<HTMLElement>('.ra-matrix').forEach(initMatrix);
</script>

<style>
  .responsible-matrix {
    color: var(--color-text);
  }

  .lede {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-xl);
    max-width: 36rem;
  }

  .ra-matrix {
    --ra-feature-col-width: 14rem;
    scroll-margin-top: 5rem;
  }

  .matrix-section h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--color-text-heading);
    margin: 0 0 var(--space-md);
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  /* No internal scroll wrapper: the table extends past the page container if
     necessary and the page itself handles horizontal overflow. This lets the
     sticky thead actually stick (a contained scroll context broke it) and
     means pinch-zoom-out on mobile reveals more of the table. */
  .ra-matrix__scroll {
    /* intentionally no overflow — see comment above */
  }

  .matrix-table {
    --matrix-rule: color-mix(in srgb, var(--color-border), var(--color-text) 35%);
    width: 100%;
    /* auto layout so product columns grow to fit their natural (nowrap) name;
       the dim column is held to --ra-feature-col-width via max-width + wrap so
       it doesn't widen on the wide-viewport "all products selected" case. */
    table-layout: auto;
    border-collapse: separate;
    border-spacing: 0;
    font-size: var(--font-size-sm);
  }

  .matrix-table th,
  .matrix-table td {
    padding: 0.6rem 0.75rem;
    vertical-align: top;
    text-align: left;
    border-bottom: 1px solid var(--matrix-rule);
    border-right: 1px solid var(--color-border);
  }

  .matrix-table td {
    vertical-align: middle;
  }

  .matrix-table th:last-child,
  .matrix-table td:last-child {
    border-right: 0;
  }

  /* sticky thead — pins below the page nav (--page-nav-stuck-height is set
     by the IntersectionObserver in [...slug].astro when the pill-nav stuck).
     `- 1px` matches the stuck nav's `top: -1px` shift so the two are flush. */
  .matrix-table thead th {
    position: sticky;
    top: calc(var(--page-nav-stuck-height, 0px) - 1px);
    z-index: 2;
    background: var(--color-bg);
    border-bottom: 1px solid var(--matrix-rule);
  }

  /* sticky-left feature column */
  .matrix-table tbody th[scope="row"] {
    position: sticky;
    left: 0;
    z-index: 2;
    background: var(--color-bg);
    border-right: 1px solid var(--matrix-rule);
  }

  [data-contrast="high"] .matrix-table tbody th[scope="row"] {
    border-right-width: 2px;
  }

  /* top-left intersection (sticky-top from thead rule above; sticky-left here) */
  .matrix-table thead .dim-col,
  .matrix-table thead .ra-feature-head {
    left: 0;
    z-index: 3;
    border-right: 1px solid var(--matrix-rule);
  }

  .dim-col {
    width: var(--ra-feature-col-width);
    max-width: var(--ra-feature-col-width);
  }

  .matrix-table tbody th[scope="row"] {
    width: var(--ra-feature-col-width);
    max-width: var(--ra-feature-col-width);
    overflow-wrap: break-word;
  }

  .product-col {
    /* Each product column sizes to its (nowrap) name. 7rem floor keeps the
       narrowest products (e.g. "Euria") from collapsing under their cell
       content; longer names ("Earthly Insight", "TreadLightlyAI") expand
       the column without wrapping. */
    min-width: 7rem;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 600;
    white-space: nowrap;
    text-transform: none;
    letter-spacing: 0;
  }

  .ra-product-link {
    color: var(--color-text-heading);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
  }

  .ra-product-link :global(svg) {
    color: var(--color-text-faint);
  }

  .ra-product-link:hover,
  .ra-product-link:focus-visible {
    color: var(--color-accent);
  }

  .dim-label {
    font-weight: 400;
    color: var(--color-text-heading);
  }

  /* Group header: the cell itself scrolls with the row, but its inner div is
     position:sticky;left:0 so the label stays anchored. Wrapping the sticky
     onto a div is the cross-browser-reliable pattern; sticky on <th colspan>
     directly is patchy in Chrome/Android. */
  .ra-group-header th {
    padding: 0;
    border-bottom: 1px solid var(--matrix-rule);
    background: var(--color-bg);
  }

  .ra-group-sticky {
    position: sticky;
    left: 0;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    padding: var(--space-md) 0.75rem 0.4rem;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--font-size-sm);
    color: var(--color-text-heading);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    background: var(--color-bg);
  }

  .cell {
    color: var(--color-text);
    max-width: 12rem;
    word-break: break-word;
  }

  .cell-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .detail {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .cell--yes :global(svg) { color: var(--color-verdict-true); flex-shrink: 0; }
  .cell--no :global(svg) { color: var(--color-verdict-false); flex-shrink: 0; }
  /* no-good = "the answer is no, and that's the good outcome" (e.g. no data
     used for training). Renders as a GREEN X — semantically positive. */
  .cell--no-good :global(svg) { color: var(--color-verdict-true); flex-shrink: 0; }
  .cell--partial :global(svg) { color: var(--color-verdict-mixed); flex-shrink: 0; }
  .cell--planned :global(svg) { color: var(--color-kind-report); flex-shrink: 0; }
  .cell--unknown :global(svg) { color: var(--color-text-faint); flex-shrink: 0; }

  .na {
    color: var(--color-text-faint);
  }

  .product-col :global(svg) {
    color: var(--color-text-faint);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .caption-area {
    margin: var(--space-md) 0 var(--space-xl);
  }

  .caption {
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    margin: 0 0 var(--space-sm);
  }

  .legend-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .legend-label {
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .legend {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem var(--space-md);
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
  }

  .legend-note {
    color: var(--color-text-faint);
    opacity: 0.75;
  }

  .legend-item--yes :global(svg) { color: var(--color-verdict-true); }
  .legend-item--no :global(svg) { color: var(--color-verdict-false); }
  .legend-item--no-good :global(svg) { color: var(--color-verdict-true); }
  .legend-item--partial :global(svg) { color: var(--color-verdict-mixed); }
  .legend-item--unknown :global(svg) { color: var(--color-text-faint); }

  /* Mobile: shrink Feature col to fit the longest label word; allow the
     table to extend past the page container so the page horizontal-scrolls
     naturally. Ideal column hides — editorial annotation that doesn't earn
     its width on small viewports; the editorial-pick footnote remains. */
  @media (max-width: 640px) {
    .ra-matrix {
      --ra-feature-col-width: 7rem;
    }

    .matrix-table {
      min-width: 0;
      font-size: var(--font-size-xs);
    }

    .matrix-table th,
    .matrix-table td {
      padding: 0.5rem 0.5rem;
    }

    .matrix-table tbody th[scope="row"] {
      font-size: var(--font-size-xs);
      word-break: break-word;
      hyphens: auto;
      min-width: 5rem;
    }

    .product-col {
      font-size: var(--font-size-sm);
      /* Keep product names on one line (e.g. "Viro AI" must not wrap). */
      white-space: nowrap;
      min-width: 5rem;
    }

    .ra-group-sticky {
      padding: var(--space-sm) 0.5rem 0.3rem;
    }
  }

  .landscape-nudge {
    display: none;
  }

  @media (max-width: 640px) and (orientation: portrait) {
    .landscape-nudge {
      display: block;
      font-size: var(--font-size-xs);
      color: var(--color-text-faint);
      margin: 0 0 var(--space-sm);
    }
  }

</style>

<style is:global set:html={`
${activeProducts.map((p) => `
  .ra-matrix[data-hidden-product~="${p.key}"] [data-product-key="${p.key}"] { display: none; }
`).join('')}
`} />
