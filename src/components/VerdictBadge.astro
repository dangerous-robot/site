---
import { VERDICT_LABELS, VERDICT_TOOLTIP } from '../lib/verdict';
interface Props {
  verdict: string;
  size?: 'sm' | 'md';
}
const { verdict, size = 'md' } = Astro.props;
const label = VERDICT_LABELS[verdict as keyof typeof VERDICT_LABELS] ?? verdict;
const tooltip = VERDICT_TOOLTIP[verdict as keyof typeof VERDICT_TOOLTIP] ?? '';
---
<span class:list={['chip', 'verdict-badge', `verdict-${verdict}`, size]} title={tooltip}>
  {label}
</span>
<style>
/* Verdict ranks strongest in the chip family via deeper tint + bold. */
.verdict-badge {
  --chip-tint: 25%;
  padding: var(--space-xs) var(--space-sm);
  font-size: var(--font-size-xs);
  font-weight: 700;
}
.verdict-badge.sm { font-size: var(--font-size-2xs); padding: 2px var(--space-xs); }
.verdict-true       { --chip-color: var(--color-verdict-true); }
.verdict-mostly-true { --chip-color: var(--color-verdict-mostly-true); }
.verdict-mixed      { --chip-color: var(--color-verdict-mixed); }
.verdict-mostly-false { --chip-color: var(--color-verdict-mostly-false); }
.verdict-false      { --chip-color: var(--color-verdict-false); }
.verdict-unverified { --chip-color: var(--color-verdict-unverified); }
.verdict-not-applicable { --chip-color: var(--color-verdict-not-applicable); font-style: italic; }
</style>
