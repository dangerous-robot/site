---
interface Product {
  key: string;
  name: string;
  status: 'active' | 'excluded';
}

interface Group {
  key: string;
  label: string;
}

interface Props {
  products: Product[];
  groups: Group[];
  initiallyHiddenProducts?: string[];
}

const { products, groups, initiallyHiddenProducts = [] } = Astro.props;
const activeProducts = products.filter((p) => p.status === 'active');
const hiddenSet = new Set(initiallyHiddenProducts);
const isProductPressed = (key: string) => (hiddenSet.has(key) ? 'false' : 'true');
---
<details class="ra-filters-details">
  <summary class="ra-filters-summary">
    <span class="ra-filters-summary__label">Filters</span>
    <span class="ra-filters-summary__hint">show / hide products and groups</span>
  </summary>
  <div class="ra-filters" role="group" aria-label="Matrix filters">
    <div class="ra-filters__row">
      <span class="ra-filters__label">Products</span>
      <div class="ra-filters__chips">
        {activeProducts.map((p) => (
          <span class="ra-chip-wrap">
            <button
              type="button"
              class="ra-chip"
              aria-pressed={isProductPressed(p.key)}
              data-filter-product={p.key}
            >{p.name}</button>
            <button
              type="button"
              class="ra-chip-only"
              aria-label={`Show only ${p.name}`}
              data-filter-only-product={p.key}
            >only</button>
          </span>
        ))}
      </div>
    </div>
    <div class="ra-filters__row">
      <span class="ra-filters__label">Groups</span>
      <div class="ra-filters__chips">
        {groups.map((g) => (
          <span class="ra-chip-wrap">
            <button
              type="button"
              class="ra-chip"
              aria-pressed="true"
              data-filter-group={g.key}
            >{g.label}</button>
            <button
              type="button"
              class="ra-chip-only"
              aria-label={`Show only ${g.label}`}
              data-filter-only-group={g.key}
            >only</button>
          </span>
        ))}
        <button
          type="button"
          class="ra-filters__reset"
          data-filter-reset
          aria-label="Show all products and groups"
        >Reset</button>
      </div>
    </div>
  </div>
</details>

<script>
  // Open the filter disclosure by default on viewports wide enough to absorb
  // the height; keep it collapsed on mobile so the matrix isn't pushed down.
  const filtersDetails = document.querySelectorAll<HTMLDetailsElement>('.ra-filters-details');
  if (window.matchMedia('(min-width: 640px)').matches) {
    filtersDetails.forEach((d) => { d.open = true; });
  }
</script>

<style>
  .ra-filters-details {
    margin: 0 0 var(--space-lg);
  }

  .ra-filters-summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-sm);
    padding: var(--space-xs) 0;
    color: var(--color-text-muted);
  }

  .ra-filters-summary::-webkit-details-marker { display: none; }

  .ra-filters-summary::before {
    content: "▸";
    display: inline-block;
    font-size: 0.7em;
    color: var(--color-text-faint);
  }

  .ra-filters-details[open] > .ra-filters-summary::before {
    content: "▾";
  }

  .ra-filters-summary__label {
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }

  .ra-filters-summary__hint {
    font-size: var(--font-size-2xs);
    color: var(--color-text-faint);
  }

  .ra-filters-details[open] .ra-filters {
    margin-top: var(--space-sm);
  }

  .ra-filters {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin: 0;
  }

  .ra-filters__row {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .ra-filters__row + .ra-filters__row {
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .ra-filters__label {
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    min-width: 4.5rem;
  }

  .ra-filters__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    flex: 1;
  }

  .ra-chip-wrap {
    display: inline-flex;
    align-items: stretch;
  }

  .ra-chip {
    font: inherit;
    font-size: var(--font-size-xs);
    color: var(--color-text);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    cursor: pointer;
    line-height: 1.3;
  }

  .ra-chip-wrap .ra-chip {
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
    border-right-width: 0;
  }

  /* "(only)" is a secondary sub-action attached to its chip: smaller, fainter,
     and only fully visible on hover/focus of the wrap. The visible 1px left
     divider does the affordance work; the rest of the border softens. */
  .ra-chip-only {
    font: inherit;
    font-size: var(--font-size-2xs);
    color: var(--color-text-faint);
    background: transparent;
    border: 1px solid var(--color-border);
    border-left: 1px solid var(--color-border);
    border-radius: 999px;
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
    padding: 0.2rem 0.5rem;
    cursor: pointer;
    line-height: 1.3;
    opacity: 0.65;
  }

  .ra-chip-wrap:hover .ra-chip-only,
  .ra-chip-only:focus-visible {
    opacity: 1;
    color: var(--color-text-muted);
  }

  /* Selected = visible. Faint accent tint plus an accent border — strong
     enough to read as the selected affordance without dominating the row. */
  .ra-chip[aria-pressed="true"] {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-text);
    border-color: var(--color-accent);
  }

  /* When a chip is pressed (product/group hidden), keep the "(only)" affordance
     readable against the rest of the row by aligning its border with the
     pressed neighbor. */
  .ra-chip[aria-pressed="true"] + .ra-chip-only {
    border-left-color: var(--color-accent);
  }

  [data-contrast="high"] .ra-chip[aria-pressed="true"] {
    background: color-mix(in srgb, var(--color-accent) 24%, transparent);
    outline: 1px solid var(--color-accent);
    outline-offset: -3px;
  }

  /* Reset is a different action class from the filter chips: borderless,
     muted, lives at the end of the Groups row so it sits with the controls
     it resets, not on a third orphan row. */
  .ra-filters__reset {
    font: inherit;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    background: transparent;
    border: 0;
    padding: 0.2rem 0.4rem;
    margin-left: auto;
    cursor: pointer;
    line-height: 1.3;
    text-decoration: none;
  }

  .ra-filters__reset:hover,
  .ra-filters__reset:focus-visible {
    color: var(--color-text);
    text-decoration: underline;
  }
</style>
