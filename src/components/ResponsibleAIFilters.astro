---
interface Product {
  key: string;
  name: string;
  status: 'active' | 'excluded';
}

interface Props {
  products: Product[];
  initiallyHiddenProducts?: string[];
}

const { products, initiallyHiddenProducts = [] } = Astro.props;
const activeProducts = products.filter((p) => p.status === 'active');
const hiddenSet = new Set(initiallyHiddenProducts);
const isProductPressed = (key: string) => (hiddenSet.has(key) ? 'false' : 'true');
---
<details class="ra-filters-details">
  <summary class="ra-filters-summary">
    <span class="ra-filters-summary__label">Filters</span>
    <span class="ra-filters-summary__hint">show / hide products</span>
  </summary>
  <div class="ra-filters" role="group" aria-label="Matrix filters">
    <div class="ra-filters__row">
      <span class="ra-filters__label">Products</span>
      <div class="ra-filters__chips">
        {activeProducts.map((p) => (
          <button
            type="button"
            class="ra-chip"
            aria-pressed={isProductPressed(p.key)}
            data-filter-product={p.key}
          >{p.name}</button>
        ))}
        <button
          type="button"
          class="ra-filters__reset"
          data-filter-reset
          aria-label="Show all products"
        >Reset</button>
      </div>
    </div>
  </div>
</details>

<style>
  .ra-filters-details {
    margin: 0 0 var(--space-lg);
  }

  .ra-filters-summary {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-sm);
    padding: var(--space-xs) 0;
    color: var(--color-text-muted);
  }

  .ra-filters-summary::-webkit-details-marker { display: none; }

  .ra-filters-summary::before {
    content: "▸";
    display: inline-block;
    font-size: 0.95em;
    color: var(--color-text);
  }

  .ra-filters-details[open] > .ra-filters-summary::before {
    content: "▾";
  }

  .ra-filters-summary__label {
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
  }

  .ra-filters-summary__hint {
    font-size: var(--font-size-2xs);
    color: var(--color-text-faint);
  }

  .ra-filters-details[open] .ra-filters {
    margin-top: var(--space-sm);
  }

  .ra-filters {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin: 0;
    /* Indent the inner rows under the disclosure marker so the Products
       row visually sits within the Filters group rather than aligning to
       the page edge. */
    padding-left: var(--space-md);
  }

  .ra-filters__row {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .ra-filters__label {
    font-family: var(--font-heading);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    min-width: 4.5rem;
  }

  .ra-filters__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    flex: 1;
  }

  .ra-chip {
    font: inherit;
    font-size: var(--font-size-xs);
    color: var(--color-text);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.2rem 0.7rem;
    cursor: pointer;
    line-height: 1.3;
  }

  /* Selected = visible. Faint accent tint plus an accent border — strong
     enough to read as the selected affordance without dominating the row. */
  .ra-chip[aria-pressed="true"] {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-text);
    border-color: var(--color-accent);
  }

  [data-contrast="high"] .ra-chip[aria-pressed="true"] {
    background: color-mix(in srgb, var(--color-accent) 24%, transparent);
    outline: 1px solid var(--color-accent);
    outline-offset: -3px;
  }

  /* Reset is a different action class from the filter chips: borderless,
     muted, sits at the end of the row so it lives with the controls it
     resets. */
  .ra-filters__reset {
    font: inherit;
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    background: transparent;
    border: 0;
    padding: 0.2rem 0.4rem;
    margin-left: auto;
    cursor: pointer;
    line-height: 1.3;
    text-decoration: none;
  }

  .ra-filters__reset:hover,
  .ra-filters__reset:focus-visible {
    color: var(--color-text);
    text-decoration: underline;
  }
</style>
