---
import Breadcrumb from './Breadcrumb.astro';
import ObjectTypeIcon from './ObjectTypeIcon.astro';
import { ENTITY_TYPE_LABELS } from '../lib/entityTypes';

interface Props {
  crumbs: { label: string; href?: string }[];
  type: string;
  title: string;
}

const { crumbs, type, title } = Astro.props;
---

<header class="page-header">
  <div class="breadcrumb-row">
    <Breadcrumb crumbs={crumbs} />
  </div>
  <h1 class="page-title">{title}</h1>
  <div class="item-meta">
    <div class="icon-col">
      <div class="icon-box">
        <ObjectTypeIcon type={type} size={28} />
      </div>
      <span class="type-label">{ENTITY_TYPE_LABELS[type] ?? type}</span>
    </div>
    <div class="meta-col">
      <slot />
    </div>
  </div>
</header>

<style>
  header.page-header {
    margin-bottom: var(--space-xl);
  }

  .breadcrumb-row {
    margin-bottom: var(--space-sm);
  }

  h1.page-title {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .item-meta {
    display: grid;
    grid-template-columns: 60px 1fr;
    column-gap: var(--space-md);
  }

  .icon-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    padding-top: 3px;
  }

  .icon-box {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
  }

  .type-label {
    font-size: var(--font-size-2xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-faint);
    text-align: center;
    line-height: 1.3;
  }

  .meta-col {
    margin-bottom: var(--space-md);
  }
</style>
