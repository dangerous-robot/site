---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entities = await getCollection('entities');
const claims = await getCollection('claims');
const sources = await getCollection('sources');
const standards = await getCollection('standards');

const companies = entities.filter(e => e.data.type === 'company');
const products = entities.filter(e => e.data.type === 'product');
---
<Base title="Dangerous Robot — AI transparency research">
  <div class="home-lead">
    <h1>Dangerous Robot</h1>
    <p class="tagline">Structured research connecting AI product claims to verifiable sources.</p>
  </div>
  <div class="count-strip">
    <span><strong>{companies.length}</strong> companies</span>
    <span class="sep">·</span>
    <span><strong>{products.length}</strong> products</span>
    <span class="sep">·</span>
    <span><strong>{claims.length}</strong> claims</span>
    <span class="sep">·</span>
    <span><strong>{standards.length}</strong> standards</span>
  </div>
  <nav class="section-cards" aria-label="Browse sections">
    <a href="/companies" class="section-card">
      <strong>Companies</strong>
      <span>{companies.length} tracked</span>
    </a>
    <a href="/products" class="section-card">
      <strong>Products</strong>
      <span>{products.length} tracked</span>
    </a>
    <a href="/claims" class="section-card">
      <strong>Claims</strong>
      <span>{claims.length} assessed</span>
    </a>
    <a href="/standards" class="section-card">
      <strong>Standards</strong>
      <span>{standards.length} templates</span>
    </a>
  </nav>
</Base>
<style>
.home-lead { margin-bottom: var(--space-xl); }
.home-lead h1 { margin-bottom: var(--space-xs); }
.tagline { color: var(--color-text-muted); font-size: 1.05rem; }
.count-strip {
  display: flex; flex-wrap: wrap; gap: var(--space-sm);
  padding: var(--space-md) 0;
  font-size: var(--font-size-sm); color: var(--color-text-muted);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
  margin-bottom: var(--space-xl);
}
.count-strip strong { color: var(--color-text); }
.count-strip .sep { color: var(--color-border); }
.section-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: var(--space-md);
}
.section-card {
  display: flex; flex-direction: column; gap: var(--space-xs);
  padding: var(--space-lg);
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  text-decoration: none; color: inherit;
}
.section-card:hover { border-color: var(--color-accent); }
.section-card strong { font-size: 1.05rem; color: var(--color-text); }
.section-card span { font-size: var(--font-size-xs); color: var(--color-text-faint); }
</style>
