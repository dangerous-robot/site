---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../lib/research';

const entities = await getCollection('entities');
const allClaims = await getCollection('claims', ({ data }) => data.status === 'published');
const allSources = await getCollection('sources');

const companies = entities.filter((e) => e.data.type === 'company');
const products = entities.filter((e) => e.data.type === 'product');

const sections = [
  { n: '01', label: 'Companies', meta: `${companies.length} tracked`, href: '/companies' },
  { n: '02', label: 'Products', meta: `${products.length} tracked`, href: '/products' },
  { n: '03', label: 'Topics', meta: `${CATEGORIES.length} areas`, href: '/topics' },
  { n: '04', label: 'Claims', meta: `${allClaims.length} assessed`, href: '/claims' },
  { n: '05', label: 'Sources', meta: `${allSources.length} indexed`, href: '/sources' },
];

const navLinks = [
  { href: '/companies', label: 'Companies' },
  { href: '/products', label: 'Products' },
  { href: '/topics', label: 'Topics' },
  { href: '/claims', label: 'Claims' },
  { href: '/sources', label: 'Sources' },
  { href: '/criteria', label: 'Criteria' },
  { href: '/faq', label: 'FAQ' },
];

// Archive log construction — we render two lines that look like we caught
// the archive mid-stream: each line begins with the trailing words of some
// other claim, then shows two or three real verdict/title pairs.
const featuredVerdicts = new Set(['false', 'mostly-false', 'unverified', 'mixed']);
const pool = allClaims
  .filter((c) => featuredVerdicts.has(c.data.verdict))
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((c) => ({ verdict: c.data.verdict as string, title: c.data.title as string }));

const manualClaim = {
  verdict: 'false',
  title: 'At least one major AI company scores a C or higher on existential threats',
};

const fmtVerdict = (v: string) => v.replace(/-/g, ' ').toUpperCase();
const tail = (s: string, n = 4) => s.split(/\s+/).slice(-n).join(' ');

const fallback = [
  { verdict: 'unverified', title: 'ChatGPT is hosted on renewable energy' },
  { verdict: 'mixed', title: 'Google publishes a sustainability or ESG report' },
  { verdict: 'mostly-false', title: 'Anthropic publishes detailed training-data disclosures' },
  { verdict: 'false', title: 'OpenAI discloses cumulative model training compute' },
];
const src = [...pool, ...fallback];

// Skip the mandatory topic so we don't duplicate.
const claimA = src[0];
const claimB = src[1];
const claimC = src[2];
const claimD = src[3];

const frag1 = tail(src[4]?.title ?? 'on verifiable sources', 4);
const frag2 = tail(src[5]?.title ?? 'training', 1);

const line1 = { fragment: frag1, items: [manualClaim, claimA] };
const line2 = { fragment: frag2, items: [claimB, claimC, claimD] };
---

<Base title="Dangerous Robot — AI transparency research" chrome="minimal" layout="bare">
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-logo-wrap" id="hero-logo-wrap" aria-hidden="true">
      <img src="/dr-logo.png" alt="" class="hero-logo hero-logo--base" id="hero-logo" />
      <img src="/dr-logo.png" alt="" class="hero-logo hero-logo--ghost" />
    </div>

    <div class="hero-scan" aria-hidden="true"></div>

    <button
      class="hero-burger"
      id="hero-burger"
      type="button"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="hero-nav"
    >
      <span class="hero-burger__bars" aria-hidden="true">
        <span></span><span></span><span></span>
      </span>
      <span class="hero-burger__close" aria-hidden="true">
        <span></span><span></span>
      </span>
    </button>

    <div class="hero-grid">
      <header class="hero-head">
        <p class="hero-meta" aria-hidden="true">
          <span>DR</span>
          <span class="hero-meta__dot">&middot;</span>
          <span>vol.001</span>
          <span class="hero-meta__dot">&middot;</span>
          <span>a transparency index</span>
        </p>

        <h1 class="hero-title" id="hero-title">
          <span class="hero-title__row">
            <span class="hero-title__word" data-text="Dangerous">Dangerous</span>
          </span>
          <span class="hero-title__row hero-title__row--indent">
            <span class="hero-title__word hero-title__word--italic" data-text="Robot">Robot</span>
          </span>
        </h1>

        <p class="hero-tag">
          Open, accountable research on AI companies: built by people, powered by AI.
        </p>
      </header>

      <ol class="hero-cards" aria-label="Browse the archive">
        {sections.map((s) => (
          <li class="hero-card-item">
            <a class="nav-card" href={s.href}>
              <span class="nav-card__num" aria-hidden="true">{s.n}</span>
              <span class="nav-card__label">{s.label}</span>
              <span class="nav-card__meta">{s.meta}</span>
              <span class="nav-card__arrow" aria-hidden="true">&rarr;</span>
            </a>
          </li>
        ))}
      </ol>
    </div>

    <!-- Archive log: two horizontal strips, each beginning mid-claim -->
    <div class="hero-log" aria-label="Archive index">
      <div class="hero-log__line">
        <span class="hero-log__frag">&hellip;{line1.fragment}</span>
        {line1.items.map((c) => (
          <span class="hero-log__pair">
            <span class={`hero-log__verdict hero-log__verdict--${c.verdict}`}>{fmtVerdict(c.verdict)}</span>
            <span class="hero-log__body">{c.title}</span>
          </span>
        ))}
      </div>
      <div class="hero-log__line hero-log__line--offset">
        <span class="hero-log__frag">&hellip;{line2.fragment}</span>
        {line2.items.map((c) => (
          <span class="hero-log__pair">
            <span class={`hero-log__verdict hero-log__verdict--${c.verdict}`}>{fmtVerdict(c.verdict)}</span>
            <span class="hero-log__body">{c.title}</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <div
    class="hero-nav"
    id="hero-nav"
    role="dialog"
    aria-modal="true"
    aria-labelledby="hero-nav-label"
    hidden
  >
    <div class="hero-nav__inner">
      <p class="hero-nav__eyebrow" id="hero-nav-label">Index</p>
      <nav aria-label="Site sections">
        <ol>
          {navLinks.map((l, i) => (
            <li>
              <a href={l.href}>
                <span class="hero-nav__num">{String(i + 1).padStart(2, '0')}</span>
                <span class="hero-nav__label">{l.label}</span>
                <span class="hero-nav__arrow" aria-hidden="true">&rarr;</span>
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </div>
  </div>
</Base>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding: clamp(var(--space-lg), 4vw, var(--space-2xl));
    padding-top: calc(clamp(var(--space-md), 2.2vw, var(--space-lg)) + 18px);
    padding-bottom: clamp(var(--space-xl), 6vh, var(--space-2xl));
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-rows: 1fr auto;
    gap: clamp(var(--space-xl), 5vh, 4rem);
    isolation: isolate;
  }

  /* -------- oversized logo (wrap + ghost)
     Sized and positioned entirely in vh so horizontal viewport changes
     never move the logo vertically. -------- */
  .hero-logo-wrap {
    position: absolute;
    left: -18vh;
    bottom: calc(-25vh - 0.4em);
    width: 125vh;
    height: 125vh;
    pointer-events: none;
    z-index: 0;
    transform: rotate(-8deg);
    transform-origin: 50% 50%;
  }
  @media (max-width: 680px) {
    .hero-logo-wrap {
      left: 0;
      width: min(125vh, 100vw);
      height: min(125vh, 100vw);
      bottom: 20vh;
    }
  }
  .hero-logo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    user-select: none;
    max-width: none;
    max-height: none;
    will-change: transform, opacity;
    transition: opacity 700ms ease;
  }
  .hero-logo--base { opacity: 0.2; }
  .hero-logo--ghost { opacity: 0; transition: none; }

  /* Base logo: fully themed. Ghost: rendered at a grey mid-tone so
     its flash never reads as a stark black-or-white shape. */
  :global([data-theme="light"]) .hero-logo--base { filter: none; opacity: 0.18; }
  :global([data-theme="dark"])  .hero-logo--base { filter: invert(1) brightness(0.92); }
  :global([data-theme="light"]) .hero-logo--ghost { filter: invert(1) brightness(0.65); }
  :global([data-theme="dark"])  .hero-logo--ghost { filter: invert(1) brightness(0.35); }

  .hero-logo--base.is-dimmed { opacity: 0.14; }
  :global([data-theme="light"]) .hero-logo--base.is-dimmed { opacity: 0.08; }

  /* -------- scanlines -------- */
  .hero-scan {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0,
      transparent 3px,
      rgba(255, 255, 255, 0.015) 3px,
      rgba(255, 255, 255, 0.015) 4px
    );
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: overlay;
  }
  :global([data-theme="light"]) .hero-scan {
    background: repeating-linear-gradient(
      0deg,
      transparent 0,
      transparent 3px,
      rgba(0, 0, 0, 0.02) 3px,
      rgba(0, 0, 0, 0.02) 4px
    );
  }

  /* -------- hamburger (plain div bars — no SVG, no currentColor quirks) -------- */
  .hero-burger {
    position: fixed;
    top: clamp(var(--space-md), 2.2vw, var(--space-lg));
    right: clamp(var(--space-md), 2.2vw, var(--space-lg));
    z-index: 400;
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-heading);
    cursor: pointer;
    padding: 0;
    border-radius: 0;
    box-shadow: 0 1px 12px rgba(0, 0, 0, 0.35);
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }
  :global([data-theme="light"]) .hero-burger {
    box-shadow: 0 1px 10px rgba(0, 0, 0, 0.08);
  }
  .hero-burger:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .hero-burger:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }
  .hero-burger[aria-expanded="true"] { background: var(--color-bg); }

  .hero-burger__bars,
  .hero-burger__close {
    grid-area: 1 / 1;
    display: block;
    position: relative;
    width: 22px;
    height: 18px;
    transition: opacity 0.18s ease;
  }
  .hero-burger__bars > span {
    display: block;
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: currentColor;
  }
  .hero-burger__bars > span:nth-child(1) { top: 0; }
  .hero-burger__bars > span:nth-child(2) { top: 50%; transform: translateY(-50%); }
  .hero-burger__bars > span:nth-child(3) { bottom: 0; }

  .hero-burger__close { opacity: 0; }
  .hero-burger__close > span {
    display: block;
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background: currentColor;
    transform-origin: center;
  }
  .hero-burger__close > span:nth-child(1) { transform: translateY(-50%) rotate(45deg); }
  .hero-burger__close > span:nth-child(2) { transform: translateY(-50%) rotate(-45deg); }

  .hero-burger[aria-expanded="true"] .hero-burger__bars { opacity: 0; }
  .hero-burger[aria-expanded="true"] .hero-burger__close { opacity: 1; }

  /* -------- main grid -------- */
  .hero-grid {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: minmax(0, 3fr) minmax(0, 2fr);
    gap: clamp(var(--space-xl), 4vw, 5rem);
    align-items: start;
    width: 100%;
    max-width: 96rem;
    margin: 0 auto;
    padding: 0 0 clamp(1.5rem, 4vh, 2.5rem);
  }

  .hero-head {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(var(--space-md), 2vh, var(--space-lg));
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--font-size-2xs);
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }
  .hero-meta__dot { opacity: 0.4; }

  .hero-title {
    margin: 0;
    font-family: var(--font-wordmark);
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-heading);
    display: flex;
    flex-direction: column;
    gap: 0.05em;
    max-width: 100%;
  }
  .hero-title__row {
    display: flex;
    align-items: baseline;
    max-width: 100%;
  }
  .hero-title__row--indent { padding-left: 0.55em; }
  .hero-title__word {
    display: inline-block;
    position: relative;
    font-size: clamp(2rem, 5.2vw, 4.4rem);
    font-weight: 600;
    max-width: 100%;
    line-height: 1.15;
    will-change: transform;
    transition: opacity 600ms ease;
  }
  .hero-title__word--italic {
    font-style: normal;
    font-weight: 800;
    color: var(--color-text);
    padding-bottom: 0.14em;
  }
  .hero-title__word--italic::after {
    content: '';
    position: absolute;
    left: 0.14em;
    bottom: 0;
    width: 0.52em;
    height: 0.05em;
    background: var(--color-accent);
  }

  .hero-title__word.is-dimmed { opacity: 0.5; transition: opacity 80ms ease; }

  .hero-tag {
    margin: 0;
    max-width: 42ch;
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 1.5vw, 1.3rem);
    font-weight: 600;
    line-height: 1.5;
    color: var(--color-text);
  }

  /* -------- card stack -------- */
  .hero-cards {
    min-width: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }
  .hero-card-item { margin: 0; }

  .nav-card {
    display: grid;
    grid-template-columns: auto 1fr auto;
    grid-template-rows: auto auto;
    column-gap: clamp(var(--space-md), 2vw, var(--space-xl));
    row-gap: 0.25rem;
    align-items: baseline;
    padding: clamp(var(--space-md), 2.4vh, var(--space-xl)) var(--space-sm);
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: transform 0.4s cubic-bezier(.2,.8,.2,1),
                padding-left 0.4s cubic-bezier(.2,.8,.2,1);
  }
  .nav-card::before {
    content: '';
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width 0.5s cubic-bezier(.2,.8,.2,1);
  }
  .nav-card__num {
    grid-row: 1 / span 2;
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-faint);
    letter-spacing: 0.12em;
    align-self: center;
    transition: color 0.3s;
  }
  .nav-card__label {
    grid-column: 2;
    grid-row: 1;
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 2.6vw, 2.1rem);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-text-heading);
    transition: color 0.3s;
  }
  .nav-card__meta {
    grid-column: 2;
    grid-row: 2;
    font-family: var(--font-mono);
    font-size: var(--font-size-2xs);
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.18em;
  }
  .nav-card__arrow {
    grid-row: 1 / span 2;
    grid-column: 3;
    align-self: center;
    font-family: var(--font-mono);
    font-size: 1.4rem;
    color: var(--color-text-faint);
    opacity: 0;
    transform: translateX(-10px);
    transition: opacity 0.25s, transform 0.4s cubic-bezier(.2,.8,.2,1), color 0.25s;
  }
  .nav-card:hover {
    transform: translateX(6px);
    padding-left: calc(var(--space-sm) + 6px);
  }
  .nav-card:hover::before { width: 100%; }
  .nav-card:hover .nav-card__label { color: var(--color-text); }
  .nav-card:hover .nav-card__num { color: var(--color-accent); }
  .nav-card:hover .nav-card__arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-accent);
  }
  .nav-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }

  /* -------- archive log: two film-strip lines, each starts mid-claim -------- */
  .hero-log {
    position: relative;
    z-index: 3;
    padding-top: 0;
    display: flex;
    flex-direction: column;
    gap: 4rem;
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    line-height: 1.4;
  }
  .hero-log__line {
    display: flex;
    align-items: baseline;
    gap: clamp(1.5rem, 4vw, 3rem);
    white-space: nowrap;
    overflow: hidden;
    /* Soft fade on the right so long strips feel like they continue off-edge */
    -webkit-mask-image: linear-gradient(to right, #000 0, #000 90%, transparent 100%);
            mask-image: linear-gradient(to right, #000 0, #000 90%, transparent 100%);
  }
  .hero-log__line--offset {
    padding-left: clamp(1.5rem, 6vw, 5rem);
  }
  .hero-log__frag {
    flex: 0 0 auto;
    color: var(--color-text-faint);
    opacity: 0.5;
  }
  .hero-log__pair {
    display: inline-flex;
    gap: 0.8rem;
    align-items: baseline;
    flex: 0 0 auto;
  }
  .hero-log__verdict { font-weight: 700; }
  .hero-log__verdict--false { color: var(--color-verdict-false); }
  .hero-log__verdict--mostly-false { color: var(--color-verdict-mostly-false); }
  .hero-log__verdict--unverified { color: var(--color-verdict-unverified); }
  .hero-log__verdict--mixed { color: var(--color-verdict-mixed); }
  .hero-log__body { color: var(--color-text-muted); letter-spacing: 0.08em; }

  /* -------- nav overlay -------- */
  .hero-nav {
    position: fixed;
    inset: 0;
    z-index: 350;
    background: var(--color-bg);
    display: grid;
    place-items: center;
    padding: clamp(var(--space-xl), 8vh, 6rem) clamp(var(--space-lg), 5vw, 5rem);
    animation: overlayIn 0.3s cubic-bezier(.2,.8,.2,1) both;
  }
  .hero-nav[hidden] { display: none; }
  @keyframes overlayIn {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-nav__inner { width: 100%; max-width: 46rem; }
  .hero-nav__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--font-size-2xs);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin: 0 0 var(--space-xl) 0;
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }
  .hero-nav ol { list-style: none; margin: 0; padding: 0; }
  .hero-nav li { border-bottom: 1px solid var(--color-border); }
  .hero-nav li a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: baseline;
    gap: clamp(var(--space-md), 2vw, var(--space-xl));
    padding: clamp(var(--space-sm), 1.8vh, var(--space-md)) 0;
    text-decoration: none;
    color: var(--color-text-heading);
    font-family: var(--font-heading);
    font-size: clamp(1.7rem, 4.2vw, 2.5rem);
    line-height: 1;
    transition: color 0.22s, transform 0.4s cubic-bezier(.2,.8,.2,1);
  }
  .hero-nav__num {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    letter-spacing: 0.14em;
    min-width: 2.2em;
  }
  .hero-nav__label { grid-column: 2; }
  .hero-nav__arrow {
    grid-column: 3;
    font-family: var(--font-mono);
    font-size: 1.3rem;
    color: var(--color-text-faint);
    opacity: 0;
    transform: translateX(-10px);
    transition: opacity 0.25s, transform 0.4s cubic-bezier(.2,.8,.2,1), color 0.25s;
  }
  .hero-nav li a:hover,
  .hero-nav li a:focus-visible {
    color: var(--color-accent);
    transform: translateX(8px);
    outline: none;
  }
  .hero-nav li a:hover .hero-nav__arrow,
  .hero-nav li a:focus-visible .hero-nav__arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-accent);
  }

  /* -------- logo glitch: subtle single-ghost flash -------- */
  .hero-logo-wrap.is-glitching .hero-logo--ghost {
    animation: logoGhost 200ms ease-out both;
  }
  .hero-logo-wrap.is-glitching .hero-logo--base {
    animation: logoJolt 160ms ease-out both;
  }
  @keyframes logoGhost {
    0%   { opacity: 0; transform: translate(0, 0); }
    15%  { opacity: 0.175; transform: translate(8px, -4px); }
    60%  { opacity: 0.175; transform: translate(8px, -4px); }
    100% { opacity: 0; transform: translate(0, 0); }
  }
  @keyframes logoJolt {
    0%, 100% { transform: translate(0, 0); }
    40%      { transform: translate(-1.5px, 1px); }
    70%      { transform: translate(1px, 0); }
  }

  /* -------- wordmark glitch: muted RGB split -------- */
  .hero-title__word.is-glitching {
    animation: textGlitch 240ms steps(5, end) both;
  }
  @keyframes textGlitch {
    0%, 100% { transform: translate(0, 0); text-shadow: none; }
    20% {
      transform: translate(-1.5px, 0);
      text-shadow:
        2px 0 0 rgba(196, 78, 62, 0.25),
        -2px 0 0 rgba(66, 149, 139, 0.28);
    }
    40% {
      transform: translate(2px, -0.5px);
      text-shadow:
        -2px 0 0 rgba(196, 78, 62, 0.25),
        2px 0 0 rgba(66, 149, 139, 0.28);
    }
    60% {
      transform: translate(-1px, 0.5px);
      text-shadow:
        1.5px 0 0 rgba(196, 78, 62, 0.25),
        -1.5px 0 0 rgba(66, 149, 139, 0.28);
    }
    80% { transform: translate(0.5px, 0); text-shadow: none; }
  }

  /* -------- reduced motion (OS preference) -------- */
  @media (prefers-reduced-motion: reduce) {
    .hero-logo-wrap.is-glitching .hero-logo--ghost,
    .hero-logo-wrap.is-glitching .hero-logo--base,
    .hero-title__word.is-glitching { animation: none; }
    .hero-logo { transition: none; }
    .hero-nav { animation: none; }
    .hero-burger, .hero-burger__icon,
    .nav-card, .nav-card__arrow, .nav-card__label, .nav-card__num, .nav-card::before,
    .hero-nav li a, .hero-nav__arrow, .hero-title__word {
      transition: none !important;
    }
  }

  /* -------- reduced motion (site preference) -------- */
  :root[data-motion="reduce"] .hero-logo,
  :root[data-motion="reduce"] .hero-title__word,
  :root[data-motion="reduce"] .hero-burger,
  :root[data-motion="reduce"] .hero-burger__icon,
  :root[data-motion="reduce"] .nav-card,
  :root[data-motion="reduce"] .nav-card__arrow,
  :root[data-motion="reduce"] .nav-card__label,
  :root[data-motion="reduce"] .nav-card__num,
  :root[data-motion="reduce"] .nav-card::before,
  :root[data-motion="reduce"] .hero-nav li a,
  :root[data-motion="reduce"] .hero-nav__arrow,
  :root[data-motion="reduce"] .hero-nav {
    transition: none !important;
    animation: none;
  }

  /* Single-column stack only at phone widths where cards beside the
     wordmark would crush content. The filmstrip keeps its nowrap/clip
     behavior at every width. */
  @media (max-width: 680px) {
    .hero-grid { grid-template-columns: 1fr; }
  }
</style>

<!-- Letter spans are injected dynamically and lack Astro's scoped cid attribute,
     so their rules must live in a global block. -->
<style is:global>
  .hero-title__letter {
    display: inline-block;
    transition: opacity 600ms ease;
  }

  .hero-title__letter.is-dimmed {
    opacity: 0.5;
    transition: opacity 80ms ease;
  }

  @keyframes letterGlitch {
    0%, 100% { transform: translate(0, 0); text-shadow: none; }
    20% {
      transform: translate(-1.5px, 0);
      text-shadow:
        3px 0 0 rgba(196, 78, 62, 0.65),
        -3px 0 0 rgba(66, 149, 139, 0.70);
    }
    40% {
      transform: translate(2px, -0.5px);
      text-shadow:
        -3px 0 0 rgba(196, 78, 62, 0.65),
        3px 0 0 rgba(66, 149, 139, 0.70);
    }
    60% {
      transform: translate(-1px, 0.5px);
      text-shadow:
        2px 0 0 rgba(196, 78, 62, 0.65),
        -2px 0 0 rgba(66, 149, 139, 0.70);
    }
    80% { transform: translate(0.5px, 0); text-shadow: none; }
  }

  .hero-title__letter.is-glitching {
    animation-name: letterGlitch;
    animation-duration: var(--glitch-dur, 240ms);
    animation-timing-function: step-end;
    animation-fill-mode: both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title__letter.is-glitching { animation: none; }
    .hero-title__letter { transition: none !important; }
  }
  :root[data-motion="reduce"] .hero-title__letter.is-glitching { animation: none; }
  :root[data-motion="reduce"] .hero-title__letter { transition: none !important; }
</style>

<script is:inline>
  (function () {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      || document.documentElement.dataset.motion === 'reduce';

    const burger = document.getElementById('hero-burger');
    const overlay = document.getElementById('hero-nav');
    let lastFocus = null;

    const getFocusable = () =>
      overlay ? Array.from(overlay.querySelectorAll('a[href], button:not([disabled])')) : [];

    const openNav = () => {
      if (!overlay || !burger) return;
      lastFocus = document.activeElement;
      overlay.hidden = false;
      burger.setAttribute('aria-expanded', 'true');
      burger.setAttribute('aria-label', 'Close navigation');
      document.documentElement.style.overflow = 'hidden';
      const first = getFocusable()[0];
      if (first) first.focus();
    };

    const closeNav = () => {
      if (!overlay || !burger) return;
      overlay.hidden = true;
      burger.setAttribute('aria-expanded', 'false');
      burger.setAttribute('aria-label', 'Open navigation');
      document.documentElement.style.overflow = '';
      if (lastFocus && typeof lastFocus.focus === 'function') lastFocus.focus();
      else burger.focus();
    };

    if (burger && overlay) {
      burger.addEventListener('click', () => {
        burger.getAttribute('aria-expanded') === 'true' ? closeNav() : openNav();
      });
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeNav();
      });
      document.addEventListener('keydown', (e) => {
        if (overlay.hidden) return;
        if (e.key === 'Escape') { e.preventDefault(); closeNav(); return; }
        if (e.key === 'Tab') {
          const items = getFocusable();
          if (!items.length) return;
          const first = items[0];
          const last = items[items.length - 1];
          const active = document.activeElement;
          if (e.shiftKey && active === first) { e.preventDefault(); last.focus(); }
          else if (!e.shiftKey && active === last) { e.preventDefault(); first.focus(); }
        }
      });
    }

    if (prefersReduced) return;

    const randBetween = (min, max) => min + Math.random() * (max - min);

    const words = Array.from(document.querySelectorAll('.hero-title__word'));
    const wordLetters = words.map((word) => {
      const text = word.dataset.text || word.textContent;
      word.setAttribute('aria-label', text);
      word.innerHTML = Array.from(text).map(
        (ch) => '<span class="hero-title__letter" aria-hidden="true">' + ch + '</span>'
      ).join('');
      return Array.from(word.querySelectorAll('.hero-title__letter'));
    });

    const scheduleGlitch = (el, className, opts) => {
      const { minDur = 90, maxDur = 120, minGap = 4200, maxGap = 11500 } = opts || {};
      const tick = () => {
        el.classList.add(className);
        window.setTimeout(() => {
          el.classList.remove(className);
          window.setTimeout(tick, randBetween(minGap, maxGap));
        }, randBetween(minDur, maxDur));
      };
      window.setTimeout(tick, randBetween(700, 3700));
    };

    const pickSlice = (letters) => {
      if (!letters.length) return [];
      const len = 1 + Math.floor(Math.random() * Math.min(9, letters.length));
      const start = Math.floor(Math.random() * (letters.length - len + 1));
      const slice = letters.slice(start, start + len);
      const dropCount = Math.min(Math.floor(Math.random() * 3), slice.length - 1);
      for (let i = 0; i < dropCount; i++) {
        slice.splice(Math.floor(Math.random() * slice.length), 1);
      }
      return slice;
    };

    const glitchHoldStates = [
      { transform: 'translate(-1.5px, 0)',   textShadow: '3px 0 0 rgba(196,78,62,0.65), -3px 0 0 rgba(66,149,139,0.70)' },
      { transform: 'translate(2px, -0.5px)', textShadow: '-3px 0 0 rgba(196,78,62,0.65), 3px 0 0 rgba(66,149,139,0.70)' },
      { transform: 'translate(-1px, 0.5px)', textShadow: '2px 0 0 rgba(196,78,62,0.65), -2px 0 0 rgba(66,149,139,0.70)' },
    ];

    const scheduleGlitchLetters = (letters, opts) => {
      const { minDur = 90, maxDur = 120, minGap = 4200, maxGap = 11500 } = opts || {};
      const tick = () => {
        const slice = pickSlice(letters);
        const duration = Math.floor(randBetween(minDur, maxDur));
        const hasStraggler = slice.length > 1 && Math.random() < 0.5;
        const stragglerIdx = hasStraggler ? Math.floor(Math.random() * slice.length) : -1;
        slice.forEach((l) => {
          l.style.setProperty('--glitch-dur', duration + 'ms');
          l.classList.add('is-glitching');
        });
        window.setTimeout(() => {
          slice.forEach((l) => {
            l.classList.remove('is-glitching');
            l.style.removeProperty('--glitch-dur');
          });
          const scheduleNext = () => window.setTimeout(tick, randBetween(minGap, maxGap));
          if (stragglerIdx >= 0) {
            const stragglerDelay = randBetween(1000, 3000);
            const hold = glitchHoldStates[Math.floor(Math.random() * glitchHoldStates.length)];
            const el = slice[stragglerIdx];
            el.style.transform = hold.transform;
            el.style.textShadow = hold.textShadow;
            window.setTimeout(() => {
              el.style.removeProperty('transform');
              el.style.removeProperty('text-shadow');
              scheduleNext();
            }, stragglerDelay);
          } else {
            scheduleNext();
          }
        }, duration);
      };
      window.setTimeout(tick, randBetween(700, 3700));
    };

    const scheduleDimTargets = (getTargets, holdMs, minGap, maxGap, secondHoldMs) => {
      const applyDim = (targets) => targets.forEach((t) => t.classList.add('is-dimmed'));
      const clearDim = (targets) => targets.forEach((t) => t.classList.remove('is-dimmed'));
      const tick = () => {
        const targets = getTargets();
        applyDim(targets);
        window.setTimeout(() => {
          clearDim(targets);
          const scheduleNext = () => window.setTimeout(tick, randBetween(minGap, maxGap));
          if (!secondHoldMs) return scheduleNext();
          window.setTimeout(() => {
            const targets2 = getTargets();
            applyDim(targets2);
            window.setTimeout(() => {
              clearDim(targets2);
              scheduleNext();
            }, secondHoldMs);
          }, randBetween(180, 300));
        }, holdMs);
      };
      window.setTimeout(tick, randBetween(12000, 27000));
    };

    const logoWrap = document.getElementById('hero-logo-wrap');
    if (logoWrap) {
      scheduleGlitch(logoWrap, 'is-glitching', { minDur: 200, maxDur: 220, minGap: 7500, maxGap: 14000 });
    }
    wordLetters.forEach((letters) => {
      scheduleGlitchLetters(letters, { minDur: 150, maxDur: 350, minGap: 6250, maxGap: 12500 });
    });

    const baseLogo = document.getElementById('hero-logo');
    if (baseLogo) scheduleDimTargets(() => [baseLogo], 1100, 35000, 55000);
    wordLetters.forEach((letters, i) => {
      scheduleDimTargets(() => pickSlice(letters), 450, 40000 + i * 5000, 65000, 160);
    });
  })();
</script>
