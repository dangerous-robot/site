---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const allClaims = await getCollection("claims");

// Group claims by entity slug
const claimsByEntity = new Map<string, typeof allClaims>();
for (const claim of allClaims) {
  const entity = claim.data.entity;
  if (!claimsByEntity.has(entity)) {
    claimsByEntity.set(entity, []);
  }
  claimsByEntity.get(entity)!.push(claim);
}

const verdictCssVar: Record<string, string> = {
  true: "var(--color-verdict-true)",
  "mostly-true": "var(--color-verdict-mostly-true)",
  mixed: "var(--color-verdict-mixed)",
  "mostly-false": "var(--color-verdict-mostly-false)",
  false: "var(--color-verdict-false)",
  unverified: "var(--color-verdict-unverified)",
};
---

<Base title="Home">
  <h1>Dangerous Robot</h1>
  <p class="intro">
    Structured research backing claims about AI products and companies.
  </p>

  {
    allClaims.length === 0 ? (
      <p class="empty">No claims published yet.</p>
    ) : (
      Array.from(claimsByEntity.entries()).map(([entity, claims]) => (
        <section class="entity-group">
          <h2>
            <a href={`/entities/${entity}`}>{entity}</a>
          </h2>
          <ul class="claim-list">
            {claims.map((claim) => (
              <li>
                <span
                  class="verdict-badge"
                  style={`background: ${verdictCssVar[claim.data.verdict] || "var(--color-verdict-unverified)"}`}
                >
                  {claim.data.verdict}
                </span>
                <a href={`/claims/${claim.id}`}>{claim.data.title}</a>
              </li>
            ))}
          </ul>
        </section>
      ))
    )
  }
</Base>

<style>
  .intro {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-bottom: var(--space-xl);
  }

  .empty {
    color: var(--color-text-faint);
    font-style: italic;
  }

  .entity-group {
    margin-bottom: var(--space-xl);
  }

  .entity-group h2 {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-sm);
  }

  .claim-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .claim-list li {
    padding: var(--space-sm) 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .verdict-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-2xs);
    font-weight: bold;
    color: var(--color-on-badge);
    text-transform: uppercase;
    white-space: nowrap;
    min-width: 5.5rem;
    text-align: center;
  }
</style>
