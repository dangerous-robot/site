---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ResourcePage from '../../layouts/ResourcePage.astro';
import TurnOffGuide from '../../components/TurnOffGuide.astro';
import ResponsibleAIMatrix from '../../components/ResponsibleAIMatrix.astro';
import Lightbox from '../../components/Lightbox.astro';
import ShouldIDecisionTree from '../../components/ShouldIDecisionTree.astro';
import { buildResourceSchema } from '../../lib/resourceSchema';

export async function getStaticPaths() {
  const entries = await getCollection('resources');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'resources'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, layout, wallpaper, data, noindex } = entry.data;

const resourceSchema = buildResourceSchema(entry);

// M1 shim: derive the legacy `dimensions[]`-shaped payload from the new
// `features[]`/`products[].status` schema so the unchanged matrix component
// keeps rendering. Removed in M2 when the component is ported to the new shape.
function buildLegacyMatrixData(input: unknown): unknown {
  if (!input || typeof input !== 'object') return input;
  const d = input as Record<string, unknown>;
  const products = Array.isArray(d.products) ? (d.products as Array<Record<string, unknown>>) : [];
  const features = Array.isArray(d.features) ? (d.features as Array<Record<string, unknown>>) : [];
  const activeProducts = products
    .filter((p) => p.status !== 'excluded')
    .map(({ key, name, url }) => ({ key, name, url }));
  const excludedProducts = products
    .filter((p) => p.status === 'excluded')
    .map((p) => ({ name: p.name, reason: p.excluded_reason ?? '' }));
  const dimensions = features.map((f) => ({ label: f.label, cells: f.cells }));
  return {
    lede: d.lede,
    caption: d.caption,
    products: activeProducts,
    dimensions,
    excluded_products: excludedProducts,
    footnotes: d.footnotes,
  };
}

const matrixData = layout === 'matrix' ? buildLegacyMatrixData(data) : data;
---
<ResourcePage
  title={title}
  description={description}
  wallpaper={wallpaper}
  noindex={noindex}
  hideTitle={layout === 'tool'}
>
  <script type="application/ld+json" set:html={JSON.stringify(resourceSchema)} />

  {layout === 'guide' && (
    <TurnOffGuide data={data}>
      <Content />
    </TurnOffGuide>
  )}

  {layout === 'article' && (
    <article class="resource-article">
      <Content />
      <Lightbox />
    </article>
  )}

  {layout === 'matrix' && (
    <article class="resource-matrix">
      <Content />
      <ResponsibleAIMatrix data={matrixData} />
    </article>
  )}

  {layout === 'tool' && (
    <article class="resource-tool">
      <ShouldIDecisionTree data={data}>
        <Content />
      </ShouldIDecisionTree>
    </article>
  )}
</ResourcePage>

<style>
  .resource-article {
    max-width: 40rem;
  }

  .resource-matrix {
    max-width: 64rem;
  }

  .resource-tool {
    max-width: 44rem;
  }

  /* Article body styles for ai-safety scorecard figure and category list. */
  .resource-article :global(figure.scorecard) {
    margin: var(--space-xl) 0;
  }

  .resource-article :global(figure.scorecard img) {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }

  .resource-article :global(figure.scorecard figcaption) {
    margin-top: var(--space-sm);
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    text-align: center;
  }

  .resource-article :global(h2) {
    margin: var(--space-2xl) 0 var(--space-md);
  }

  .resource-article :global(dl.categories) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl) var(--space-2xl);
    margin: var(--space-lg) 0;
  }

  @media (max-width: 640px) {
    .resource-article :global(dl.categories) {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }

  .resource-article :global(dl.categories > dt) {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--color-text-heading);
    margin: 0 0 var(--space-xs);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-xs);
  }

  .resource-article :global(dl.categories > dd) {
    margin: 0 0 var(--space-sm);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-body);
  }

  .resource-article :global(dl.categories > dd.definition) {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    background: var(--color-code-bg);
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius-sm);
    color: var(--color-text-heading);
  }
</style>
