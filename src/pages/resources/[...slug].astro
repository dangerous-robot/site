---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ResourcePage from '../../layouts/ResourcePage.astro';
import TurnOffGuide from '../../components/TurnOffGuide.astro';
import ResponsibleAIMatrix from '../../components/ResponsibleAIMatrix.astro';
import ResponsibleAISummary from '../../components/ResponsibleAISummary.astro';
import ResponsibleAIExcluded from '../../components/ResponsibleAIExcluded.astro';
import ResponsibleAIFootnotes from '../../components/ResponsibleAIFootnotes.astro';
import Lightbox from '../../components/Lightbox.astro';
import ShouldIDecisionTree from '../../components/ShouldIDecisionTree.astro';
import { buildResourceSchema } from '../../lib/resourceSchema';
import { matrixDataSchema } from '../../content.config';

export async function getStaticPaths() {
  const entries = await getCollection('resources');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'resources'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, layout, wallpaper, data, noindex } = entry.data;

const resourceSchema = buildResourceSchema(entry);

// Layout-specific data is typed as z.unknown() at the collection level so each
// layout can validate its own shape here. Fail loudly: a schema error in a
// matrix entry should break the build, not render a degraded page.
const matrixData = layout === 'matrix' ? matrixDataSchema.parse(data) : undefined;
---
<ResourcePage
  title={title}
  description={description}
  wallpaper={wallpaper}
  noindex={noindex}
  hideTitle={layout === 'tool'}
  layout={layout === 'matrix' ? 'wide' : undefined}
>
  <script type="application/ld+json" set:html={JSON.stringify(resourceSchema)} />

  {layout === 'guide' && (
    <TurnOffGuide data={data}>
      <Content />
    </TurnOffGuide>
  )}

  {layout === 'article' && (
    <article class="resource-article">
      <Content />
      <Lightbox />
    </article>
  )}

  {layout === 'matrix' && matrixData && (
    <article class="resource-matrix">
      <nav class="pill-nav-wrap resources-pill-nav--bold" aria-label="Page sections">
        <p class="resources-pill-nav-label" aria-hidden="true">Jump to:</p>
        <div class="resources-pill-nav pill-nav-row">
          <a href="#comparison-table" data-pill-target="comparison-table">Comparison table</a>
          <a href="#footnotes" data-pill-target="footnotes">Footnotes</a>
        </div>
      </nav>
      <ResponsibleAISummary data={matrixData} />
      <Content />
      <ResponsibleAIMatrix data={matrixData} />
      <ResponsibleAIExcluded data={matrixData} />
      <ResponsibleAIFootnotes data={matrixData} />
    </article>
  )}

  {layout === 'tool' && (
    <article class="resource-tool">
      <ShouldIDecisionTree data={data}>
        <Content />
      </ShouldIDecisionTree>
    </article>
  )}
</ResourcePage>

<script>
  // Stuck-state detector for .pill-nav-wrap. A sentinel above each nav lets
  // an IntersectionObserver toggle `.is-stuck`. A ResizeObserver tracks the
  // nav's actual rendered height (including any post-class-toggle reflow)
  // and publishes it as --page-nav-stuck-height on <html>, so the matrix
  // thead can pin flush against the bottom of the stuck nav.
  const navs = document.querySelectorAll<HTMLElement>('.pill-nav-wrap');
  const updateStuckHeight = () => {
    const stuck = document.querySelector<HTMLElement>('.pill-nav-wrap.is-stuck');
    const h = stuck ? stuck.getBoundingClientRect().height : 0;
    document.documentElement.style.setProperty('--page-nav-stuck-height', `${h}px`);
  };
  navs.forEach((nav) => {
    if (nav.dataset.pillNavInit) return;
    nav.dataset.pillNavInit = '1';
    const sentinel = document.createElement('div');
    sentinel.className = 'pill-nav-sentinel';
    sentinel.setAttribute('aria-hidden', 'true');
    nav.parentNode?.insertBefore(sentinel, nav);
    const io = new IntersectionObserver(([entry]) => {
      nav.classList.toggle('is-stuck', !entry.isIntersecting);
      updateStuckHeight();
    });
    io.observe(sentinel);
    const ro = new ResizeObserver(updateStuckHeight);
    ro.observe(nav);
  });
  window.addEventListener('resize', updateStuckHeight);
  updateStuckHeight();
</script>

<style>
  .resource-article {
    max-width: 40rem;
  }

  .resource-matrix {
    /* width inherited from .content--wide on the matrix layout */
  }

  .resource-tool {
    max-width: 44rem;
  }

  /* Article body styles for ai-safety scorecard figure and category list. */
  .resource-article :global(figure.scorecard) {
    margin: var(--space-xl) 0;
  }

  .resource-article :global(figure.scorecard img) {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }

  .resource-article :global(figure.scorecard figcaption) {
    margin-top: var(--space-sm);
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    text-align: center;
  }

  .resource-article :global(h2) {
    margin: var(--space-2xl) 0 var(--space-md);
  }

  .resource-article :global(dl.categories) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl) var(--space-2xl);
    margin: var(--space-lg) 0;
  }

  @media (max-width: 640px) {
    .resource-article :global(dl.categories) {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }

  .resource-article :global(dl.categories > dt) {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--color-text-heading);
    margin: 0 0 var(--space-xs);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-xs);
  }

  .resource-article :global(dl.categories > dd) {
    margin: 0 0 var(--space-sm);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-body);
  }

  .resource-article :global(dl.categories > dd.definition) {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    background: var(--color-code-bg);
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius-sm);
    color: var(--color-text-heading);
  }
</style>
