---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import ResourcePage from '../../layouts/ResourcePage.astro';
import TurnOffGuide from '../../components/TurnOffGuide.astro';
import ResponsibleAIMatrix from '../../components/ResponsibleAIMatrix.astro';
import Lightbox from '../../components/Lightbox.astro';

export async function getStaticPaths() {
  const entries = await getCollection('resources');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'resources'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, layout, wallpaper, data } = entry.data;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: entry.data.pubDate.toISOString(),
  author: { '@type': 'Organization', name: 'Dangerous Robot' },
};

// Pull a freshest-modified date for guides whose payload carries per-platform
// last_verified ISO dates.
function maxLastVerified(payload: unknown): string | undefined {
  const platforms = (payload as { platforms?: { last_verified?: string }[] } | undefined)?.platforms;
  if (!Array.isArray(platforms)) return undefined;
  const dates = platforms
    .map((p) => p?.last_verified)
    .filter((s): s is string => typeof s === 'string')
    .map((s) => new Date(s))
    .filter((d) => !isNaN(d.getTime()));
  if (dates.length === 0) return undefined;
  return new Date(Math.max(...dates.map((d) => d.getTime()))).toISOString();
}

const dateModified = layout === 'guide' ? maxLastVerified(data) : undefined;
if (dateModified) {
  (articleSchema as Record<string, unknown>).dateModified = dateModified;
}
---
<ResourcePage
  title={title}
  description={description}
  wallpaper={wallpaper}
  crumb={title}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  {layout === 'guide' && (
    <TurnOffGuide data={data}>
      <Content />
    </TurnOffGuide>
  )}

  {layout === 'article' && (
    <article class="resource-article">
      <Content />
      <Lightbox />
    </article>
  )}

  {layout === 'matrix' && (
    <article class="resource-matrix">
      <Content />
      <ResponsibleAIMatrix data={data} />
    </article>
  )}

  {layout === 'tool' && (
    <article class="resource-article">
      <Content />
      <p class="layout-pending">
        Interactive tool layout is not yet implemented. Check back soon.
      </p>
    </article>
  )}
</ResourcePage>

<style>
  .resource-article {
    max-width: 40rem;
  }

  .resource-matrix {
    max-width: 64rem;
  }

  .layout-pending {
    margin-top: var(--space-xl);
    padding: var(--space-md);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* Article body styles for ai-safety scorecard figure and category list. */
  .resource-article :global(figure.scorecard) {
    margin: var(--space-xl) 0;
  }

  .resource-article :global(figure.scorecard img) {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }

  .resource-article :global(figure.scorecard figcaption) {
    margin-top: var(--space-sm);
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    text-align: center;
  }

  .resource-article :global(h2) {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--color-text-heading);
    margin: var(--space-2xl) 0 var(--space-md);
    line-height: 1.2;
  }

  .resource-article :global(dl.categories) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl) var(--space-2xl);
    margin: var(--space-lg) 0;
  }

  @media (max-width: 640px) {
    .resource-article :global(dl.categories) {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }

  .resource-article :global(dl.categories > dt) {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--color-text-heading);
    margin: 0 0 var(--space-xs);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-xs);
  }

  .resource-article :global(dl.categories > dd) {
    margin: 0 0 var(--space-sm);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-body);
  }

  .resource-article :global(dl.categories > dd.definition) {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    background: var(--color-code-bg);
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius-sm);
    color: var(--color-text-heading);
  }
</style>
