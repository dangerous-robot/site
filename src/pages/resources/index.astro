---
import { getCollection } from 'astro:content';
import ResourcePage from '../../layouts/ResourcePage.astro';

const entries = (await getCollection('resources'))
  .filter((e) => !e.data.noindex)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const FURTHER_READING = [
  {
    title: 'Center for Humane Technology',
    url: 'https://www.humanetech.com/',
    description: 'Advocacy for technology that serves humanity.',
  },
  {
    title: 'Future of Life Institute',
    url: 'https://futureoflife.org/',
    description: 'Research and policy for existential risk from AI.',
  },
  {
    title: 'AI Incident Database',
    url: 'https://incidentdatabase.ai/',
    description: 'Tracking real-world AI harms and failures.',
  },
  {
    title: 'Electronic Frontier Foundation: AI',
    url: 'https://www.eff.org/issues/ai',
    description: 'Digital rights and civil liberties in the age of AI.',
  },
  {
    title: 'Human Statement',
    url: 'https://humanstatement.org/',
    description: 'A declaration that AI should serve humanity, not the reverse.',
  },
];
---
<ResourcePage
  title="AI Through a Human Lens"
  description="AI literacy resources for people who don't want to cede their humanity to machines."
  eyebrow="Resources"
  lede="AI literacy resources for people who don't want to cede their humanity to machines."
  hideTitle
  wallpaper="default"
>
  <div class="hub-grid">
    <section class="hub-col">
      <h2 class="hub-col-label">Our resources</h2>
      {entries.length === 0
        ? <p class="empty">More guides coming soon.</p>
        : <ul class="hub-list">
            {entries.map((entry) => (
              <li>
                <a href={`/resources/${entry.id}`} class="hub-item">
                  <span class="hub-title">{entry.data.title}</span>
                  <span class="hub-desc">{entry.data.description}</span>
                </a>
              </li>
            ))}
          </ul>}
    </section>

    <section class="hub-col">
      <h2 class="hub-col-label">Elsewhere</h2>
      <ul class="hub-list">
        {FURTHER_READING.map((link) => (
          <li>
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="hub-item">
              <span class="hub-title">{link.title}</span>
              <span class="hub-desc">{link.description}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </div>
</ResourcePage>

<style>
  .hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: var(--space-lg);
    margin: var(--space-xl) 0;
  }

  .hub-col {
    border-top: 2px solid var(--color-accent);
    padding-top: var(--space-md);
  }

  .hub-col-label {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--color-text-heading);
  }

  .hub-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .hub-item {
    display: block;
    text-decoration: none;
    padding: 0;
  }

  .hub-item:hover .hub-title {
    text-decoration: underline;
  }

  .hub-title {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .hub-desc {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    line-height: var(--line-height-body);
  }

  .empty {
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
