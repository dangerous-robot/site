---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { CATEGORY_LABELS, CATEGORIES } from '../../lib/research';
import PageHeader from '../../components/PageHeader.astro';
import VerdictDistribution from '../../components/VerdictDistribution.astro';
import ClaimRow from '../../components/ClaimRow.astro';
import EmptyState from '../../components/EmptyState.astro';

export async function getStaticPaths() {
  return CATEGORIES.map(topic => ({ params: { topic } }));
}

const { topic } = Astro.params;
const label = CATEGORY_LABELS[topic as keyof typeof CATEGORY_LABELS] ?? topic;

const allClaims = await getCollection('claims', ({ data }) => data.status === 'published');
// A claim with topics [a, b] appears on both /topics/a and /topics/b. Per-topic
// distribution counts use these matched claims; deduplication happens at claim
// id level (the claim is the unit, the topic is the lens).
const claims = allClaims.filter(c => c.data.topics.includes(topic as any));
const entities = await getCollection('entities');

// Group by entity
const byEntity = new Map<string, typeof claims>();
for (const c of claims) {
  if (!byEntity.has(c.data.entity)) byEntity.set(c.data.entity, []);
  byEntity.get(c.data.entity)!.push(c);
}

const entityGroups = [...byEntity.entries()].map(([entityId, entityClaims]) => {
  const entity = entities.find(e => e.id === entityId);
  return {
    entityId,
    entityName: entity?.data.name ?? entityId,
    verdicts: entityClaims.map(c => c.data.verdict),
    claims: entityClaims,
  };
}).sort((a, b) => a.entityName.localeCompare(b.entityName));

// Per-topic verdict distribution: `claims` is already the topic-filtered
// list, so each entry contributes one verdict to this topic's overall.
const allVerdicts = claims.map(c => c.data.verdict);
const uniqueClaimCount = claims.length;

const topicPageTitle = `AI ${label} Claims`;
const topicDescription = `Browse AI ${label} claims on Dangerous Robot. ${uniqueClaimCount} claim${uniqueClaimCount !== 1 ? 's' : ''} across ${entityGroups.length} entit${entityGroups.length !== 1 ? 'ies' : 'y'}, with verdict and sourcing for each.`;
const topicCrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Topics', href: '/topics' },
];
---
<Base title={topicPageTitle} layout="wide" description={topicDescription}>
  <PageHeader crumbs={topicCrumbs} type="topic" title={label}>
    <p class="total-count">{uniqueClaimCount} claim{uniqueClaimCount !== 1 ? 's' : ''} across {entityGroups.length} entit{entityGroups.length !== 1 ? 'ies' : 'y'}</p>
    <div class="overall-distribution">
      <span class="dist-label">Overall</span>
      <VerdictDistribution verdicts={allVerdicts} />
    </div>
  </PageHeader>

  {entityGroups.length === 0
    ? <EmptyState message="No claims in this topic yet." />
    : entityGroups.map(group => (
      <section class="entity-group">
        <div class="entity-group-header">
          <a href={`/entities/${group.entityId}`} class="entity-link">{group.entityName}</a>
          <VerdictDistribution verdicts={group.verdicts} />
        </div>
        {group.claims.map(c => (
          <ClaimRow
            id={c.id}
            title={c.data.title}
            verdict={c.data.verdict}
            entity={c.data.entity}
            topics={c.data.topics}
            asOf={c.data.as_of instanceof Date ? c.data.as_of.toISOString().split('T')[0] : String(c.data.as_of)}
          />
        ))}
      </section>
    ))}
</Base>
<style>
.total-count { color: var(--color-text-muted); font-size: var(--font-size-sm); margin-bottom: var(--space-md); }
.overall-distribution { display: flex; align-items: center; gap: var(--space-md); }
.dist-label { font-size: var(--font-size-xs); color: var(--color-text-faint); }
.entity-group { margin-bottom: var(--space-xl); }
.entity-group-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--space-sm) 0;
  border-bottom: 2px solid var(--color-border);
  margin-bottom: var(--space-xs);
}
.entity-link { font-weight: 700; color: var(--color-accent); text-decoration: none; }
</style>
