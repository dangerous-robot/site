---
import Base from "../../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
import { buildCriteriaIndex } from "../../../lib/criteria";
import { CATEGORY_LABELS } from "../../../lib/research";
import VerdictBadge from "../../../components/VerdictBadge.astro";
import NotAssessedCell from "../../../components/NotAssessedCell.astro";
import PageHeader from "../../../components/PageHeader.astro";
import {
  VERIFICATION_STATUS_BADGE_TEXT,
  buildEntityMap,
  getEntityParent,
  resolveMadeBy,
  type VerificationStatus,
} from "../../../lib/entityTypes";
import { shouldNoindex } from "../../../lib/seo";

export async function getStaticPaths() {
  const entities = await getCollection("entities");
  return entities.map((entity) => ({
    params: { slug: entity.id },
    props: { entity },
  }));
}

const { entity } = Astro.props;
const { Content } = await render(entity);

const [allClaims, criteria, entities] = await Promise.all([
  getCollection("claims", ({ data }) => data.status === "published"),
  getCollection("criteria"),
  getCollection("entities"),
]);
const relatedClaims = allClaims.filter(
  (claim) => claim.data.entity === entity.id
);

const entityMap = buildEntityMap(entities);
const madeBy = resolveMadeBy(entity, entityMap);

const verificationStatus = entity.data.verification_status as VerificationStatus | undefined;
const verificationBadgeText =
  verificationStatus && verificationStatus !== 'verified'
    ? VERIFICATION_STATUS_BADGE_TEXT[verificationStatus]
    : '';

// Derived products list for company pages: scan entities for products whose
// parent_company points at this company. Sorted alphabetically by display name.
// No schema field; the source of truth is each product's parent_company ref.
const derivedProducts = entity.data.type === 'company'
  ? entities
      .filter(e => e.data.type === 'product' && e.data.parent_company === entity.id)
      .sort((a, b) => a.data.name.localeCompare(b.data.name))
  : [];

const founded = entity.data.founded as number | undefined;

// Subjects ignore `founded` per plan; only company/product render Facts.
const showFacts =
  (entity.data.type === 'company' && (founded || derivedProducts.length > 0)) ||
  (entity.data.type === 'product' && Boolean(founded));

// History renders the markdown body under an <h2>. Only show when the entity
// file has a non-empty body; otherwise the heading would sit above nothing.
const hasHistory = Boolean(entity.body?.trim());

// Group claims by topic. A claim with topics [a, b] appears in both
// /entities/<slug>'s "a" and "b" groups; this is intentional so the page
// reflects the multi-topic lens.
const claimsByCategory = new Map<string, typeof relatedClaims>();
for (const claim of relatedClaims) {
  for (const cat of claim.data.topics) {
    if (!claimsByCategory.has(cat)) claimsByCategory.set(cat, []);
    claimsByCategory.get(cat)!.push(claim);
  }
}
const categoriesWithClaims = [...claimsByCategory.keys()].sort();

// Criteria-applied section
const criteriaIndex = buildCriteriaIndex(allClaims);

// Filter criteria matching this entity's type
const applicableCriteria = criteria.filter(
  std => std.data.entity_type === entity.data.type
);

// Group applicable criteria by topic. A criterion with topics [a, b]
// shows under both topic headings (same multi-topic lens as claims above).
const critByCategory = new Map<string, typeof applicableCriteria>();
for (const std of applicableCriteria) {
  for (const cat of std.data.topics) {
    if (!critByCategory.has(cat)) critByCategory.set(cat, []);
    critByCategory.get(cat)!.push(std);
  }
}
const critCategoriesSorted = [...critByCategory.keys()].sort();

const typeParent = getEntityParent(entity.data.type);
const entityCrumbs = [
  { label: "Home", href: "/" },
  { label: "Research", href: "/research" },
  ...(typeParent ? [typeParent] : []),
];

const entityPageTitle = (entity.data.type === 'company' || entity.data.type === 'product')
  ? `${entity.data.name} AI ${entity.data.type === 'company' ? 'Company' : 'Product'} Claims`
  : entity.data.name;

const entityDescription = `Dangerous Robot tracks ${entity.data.name} AI ${entity.data.type} claims. ${entity.data.description}`.slice(0, 155);
---

<Base title={entityPageTitle} description={entityDescription} noindex={shouldNoindex(Astro.url.pathname)}>
  <article class="entity-detail">
    <PageHeader crumbs={entityCrumbs} type={entity.data.type} title={entity.data.name}>
      {entity.data.website && (
        <a href={entity.data.website} target="_blank" rel="noopener noreferrer" class="website-link">
          {entity.data.website} &#8599;
        </a>
      )}
      <p class="description">{entity.data.description}</p>
      {verificationBadgeText && (
        <p class="verification-badge" data-status={verificationStatus}>
          {verificationBadgeText}
        </p>
      )}
      {madeBy && (
        <p class="made-by">
          Made by <a href={madeBy.href}>{madeBy.label}</a>
        </p>
      )}
      {entity.data.type === 'company' && entity.data.legal_name && entity.data.legal_name !== entity.data.name && (
        <p class="legal-name">Legal name: <span>{entity.data.legal_name}</span></p>
      )}
    </PageHeader>

    {showFacts && (
      <section class="facts">
        <h2>Facts</h2>
        <dl class="facts-list">
          {founded && (
            <div class="fact">
              <dt>Founded</dt>
              <dd>{founded}</dd>
            </div>
          )}
          {entity.data.type === 'company' && derivedProducts.length > 0 && (
            <div class="fact">
              <dt>Products</dt>
              <dd>
                {derivedProducts.map((product, i) => (
                  <>
                    {i > 0 && <span class="fact-sep"> &middot; </span>}
                    <a href={`/research/entities/${product.id}`}>{product.data.name}</a>
                  </>
                ))}
              </dd>
            </div>
          )}
        </dl>
      </section>
    )}

    {hasHistory && (
      <section class="history body-content">
        <h2>History</h2>
        <Content />
      </section>
    )}

    <section class="related-claims">
      <h2>Claims</h2>
      {relatedClaims.length === 0 ? (
        <p class="empty">No claims for this entity yet.</p>
      ) : (
        categoriesWithClaims.map(cat => (
          <div class="category-group">
            <h3 class="category-heading">
              {CATEGORY_LABELS[cat as keyof typeof CATEGORY_LABELS] ?? cat}
            </h3>
            <ul class="claim-list">
              {claimsByCategory.get(cat)!.map((claim) => (
                <li>
                  <VerdictBadge verdict={claim.data.verdict} size="sm" />
                  <a href={`/research/claims/${claim.id}`}>
                    {claim.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      )}
    </section>

    {entity.data.type !== 'product' && entity.data.type !== 'company' && applicableCriteria.length > 0 && (
      <section class="criteria-applied">
        <h2>Criteria</h2>
        <p class="criteria-note">How this {entity.data.type} fares against applicable claim templates.</p>
        {critCategoriesSorted.map(cat => (
          <div class="std-category-group">
            <h3 class="std-category-heading">
              {CATEGORY_LABELS[cat as keyof typeof CATEGORY_LABELS] ?? cat}
            </h3>
            <div class="std-rows">
              {critByCategory.get(cat)!.map(std => {
                const byEntity = criteriaIndex.get(std.id) ?? new Map();
                const entityClaims = byEntity.get(entity.id) ?? [];
                const topClaim = entityClaims[0];
                return (
                  <div class="std-row">
                    <a href={`/research/criteria/${std.id}`} class="std-text">{std.data.text}</a>
                    <div class="std-verdict">
                      {topClaim
                        ? <VerdictBadge verdict={topClaim.verdict} size="sm" />
                        : <NotAssessedCell />
                      }
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </section>
    )}
  </article>
</Base>

<style>
  .website-link {
    font-size: var(--font-size-sm);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .made-by {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: var(--space-xs) 0 0;
  }

  .made-by a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .made-by a:hover {
    text-decoration: underline;
  }

  .legal-name {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: var(--space-xs) 0 0;
  }

  .legal-name span {
    color: var(--color-text);
  }

  .verification-badge {
    font-size: var(--font-size-sm);
    font-style: italic;
    color: var(--color-text-muted);
    border-left: 2px solid var(--color-text-faint);
    padding-left: var(--space-sm);
    margin: var(--space-sm) 0;
  }

  .description {
    color: var(--color-text-muted);
    font-size: var(--font-size-base);
    margin: 0;
  }

  .body-content {
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  .body-content :global(h2),
  .body-content :global(h3) {
    margin-top: var(--space-lg);
  }

  .facts {
    margin-bottom: var(--space-lg);
  }

  .facts h2,
  .history h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-sm);
  }

  .facts-list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .fact {
    display: flex;
    gap: var(--space-sm);
    font-size: var(--font-size-sm);
    margin: 0;
  }

  .fact dt {
    color: var(--color-text-faint);
    font-weight: 600;
    min-width: 5.5rem;
  }

  .fact dd {
    color: var(--color-text);
    margin: 0;
  }

  .fact-sep {
    color: var(--color-text-faint);
  }

  .history {
    margin-bottom: var(--space-xl);
  }

  .related-claims {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .related-claims h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-md);
  }

  .category-group {
    margin-bottom: var(--space-lg);
  }

  .category-heading {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-faint);
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .empty {
    color: var(--color-text-faint);
    font-style: italic;
  }

  .claim-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .claim-list li {
    padding: var(--space-sm) 0;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  /* Badge sits in its own column; nudge down so its top aligns with
     the cap-height of the title's first line rather than the box top. */
  .claim-list li :global(.verdict-badge) { margin-top: 2px; }

  /* Title link uses body text color in dark mode so it doesn't clash
     with the green TRUE verdict badge (link accent and verdict-true
     are both greens). Accent reappears on hover for affordance. */
  .claim-list li a {
    color: var(--color-text);
  }
  .claim-list li a:hover {
    color: var(--color-accent);
  }

  .claim-list li:last-child {
    border-bottom: none;
  }

  /* Criteria applied section */
  .criteria-applied {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }

  .criteria-applied h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-xs);
  }

  .criteria-note {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .std-category-group {
    margin-bottom: var(--space-lg);
  }

  .std-category-heading {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-faint);
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .std-rows {
    display: flex;
    flex-direction: column;
  }

  .std-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .std-row:last-child {
    border-bottom: none;
  }

  .std-text {
    flex: 1;
    font-size: var(--font-size-sm);
    color: var(--color-text);
    text-decoration: none;
  }

  .std-text:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .std-verdict {
    flex-shrink: 0;
  }
</style>
