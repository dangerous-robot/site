---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const claims = await getCollection("claims");
  return claims.map((claim) => ({
    params: { slug: claim.id },
    props: { claim },
  }));
}

const { claim } = Astro.props;
const { Content } = await render(claim);

// Resolve matching standard
const standards = await getCollection("standards");
const stem = claim.id.split("/").pop() ?? claim.id;
const standardSlug = claim.data.standard_slug ?? stem;
const matchedStandard = standards.find(s => s.id === standardSlug);

const verdictCssVar: Record<string, string> = {
  true: "var(--color-verdict-true)",
  "mostly-true": "var(--color-verdict-mostly-true)",
  mixed: "var(--color-verdict-mixed)",
  "mostly-false": "var(--color-verdict-mostly-false)",
  false: "var(--color-verdict-false)",
  unverified: "var(--color-verdict-unverified)",
};

const confidenceLabels: Record<string, string> = {
  high: "High",
  medium: "Medium",
  low: "Low",
};

const asOfDate = claim.data.as_of instanceof Date
  ? claim.data.as_of.toISOString().split("T")[0]
  : String(claim.data.as_of);
---

<Base title={claim.data.title}>
  <article class="claim-detail">
    <header>
      {matchedStandard && (
        <p class="standard-ref">
          Standard: <a href={`/standards/${matchedStandard.id}`}>{matchedStandard.data.text}</a>
        </p>
      )}
      <h1>{claim.data.title}</h1>

      <div class="meta">
        <span
          class="verdict-badge"
          style={`background: ${verdictCssVar[claim.data.verdict] || "var(--color-verdict-unverified)"}`}
        >
          {claim.data.verdict}
        </span>

        <span class="confidence">
          Confidence: {confidenceLabels[claim.data.confidence] || claim.data.confidence}
        </span>

        <span class="as-of">
          As of {asOfDate}
        </span>

        <span class="category">
          {claim.data.category}
        </span>
      </div>

      <div class="entity-link">
        Entity: <a href={`/entities/${claim.data.entity}`}>{claim.data.entity}</a>
      </div>
    </header>

    <section class="rationale">
      <Content />
    </section>

    {claim.data.sources && claim.data.sources.length > 0 && (
      <section class="sources-section">
        <h2>Sources</h2>
        <ul class="source-list">
          {claim.data.sources.map((sourceRef: string) => (
            <li>
              <a href={`/sources/${sourceRef}`}>{sourceRef}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="review-info">
      <h2>Review cadence</h2>
      <p>This claim is reviewed every {claim.data.recheck_cadence_days} days.</p>
    </section>
  </article>
</Base>

<style>
  .claim-detail header {
    margin-bottom: var(--space-xl);
  }

  .standard-ref {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-faint);
    margin-bottom: var(--space-sm);
  }

  .standard-ref a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .standard-ref a:hover {
    text-decoration: underline;
  }

  .claim-detail h1 {
    margin-bottom: var(--space-md);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .verdict-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: bold;
    color: var(--color-on-badge);
    text-transform: uppercase;
  }

  .confidence,
  .as-of,
  .category {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .entity-link {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .rationale {
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  .rationale :global(h2),
  .rationale :global(h3) {
    margin-top: var(--space-lg);
  }

  .sources-section {
    margin-bottom: var(--space-xl);
  }

  .source-list {
    list-style: none;
    padding: 0;
  }

  .source-list li {
    padding: 0.4rem 0;
  }

  .source-list li::before {
    content: "\2192 ";
    color: var(--color-text-faint);
  }

  .review-info {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-md);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .review-info h2 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-xs);
  }
</style>
