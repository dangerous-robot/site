---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { ENTITY_TYPE_PARENTS } from "../../lib/entityTypes";

export async function getStaticPaths() {
  const claims = await getCollection("claims");
  return claims.map((claim) => ({
    params: { slug: claim.id },
    props: { claim },
  }));
}

const { claim } = Astro.props;
const { Content } = await render(claim);

// Resolve matching criterion
const criteria = await getCollection("criteria");
const stem = claim.id.split("/").pop() ?? claim.id;
const criteriaSlug = claim.data.criteria_slug ?? stem;
const matchedCriteria = criteria.find(s => s.id === criteriaSlug);

// Entity lookup for breadcrumb. Omit type parent crumb when the parent index does not exist (currently /sectors).
const entities = await getCollection("entities");
const entityEntry = entities.find(e => e.id === claim.data.entity) ?? null;
const PARENT_ROUTES_AVAILABLE = new Set(["company", "product", "topic"]);
const typeParent = entityEntry && PARENT_ROUTES_AVAILABLE.has(entityEntry.data.type)
  ? ENTITY_TYPE_PARENTS[entityEntry.data.type]
  : null;
const entityLabel = entityEntry?.data.name ?? claim.data.entity;

const claimCrumbs = [
  { label: "Home", href: "/" },
  ...(typeParent ? [typeParent] : []),
  { label: entityLabel, href: `/entities/${claim.data.entity}` },
  { label: claim.data.title },
];

const verdictCssVar: Record<string, string> = {
  true: "var(--color-verdict-true)",
  "mostly-true": "var(--color-verdict-mostly-true)",
  mixed: "var(--color-verdict-mixed)",
  "mostly-false": "var(--color-verdict-mostly-false)",
  false: "var(--color-verdict-false)",
  unverified: "var(--color-verdict-unverified)",
  "not-applicable": "var(--color-verdict-not-applicable)",
};

const confidenceLabels: Record<string, string> = {
  high: "High",
  medium: "Medium",
  low: "Low",
};

const confidenceExplanations: Record<string, string> = {
  high: "Multiple independent primary sources confirm this verdict. The evidence is direct and specific to this claim.",
  medium: "Evidence is present but incomplete — sources may be secondary, partially relevant, or not fully corroborating. The verdict reflects the best available information.",
  low: "Limited sources, conflicting evidence, or significant uncertainty. Treat this verdict as a working hypothesis subject to revision.",
};

const asOfDate = claim.data.as_of instanceof Date
  ? claim.data.as_of.toISOString().split("T")[0]
  : String(claim.data.as_of);

const isDraft = claim.data.status === 'draft';
const isArchived = claim.data.status === 'archived';
const showNotice = isDraft || isArchived;

const isoDate = (d: Date | string | null | undefined): string | null => {
  if (!d) return null;
  if (d instanceof Date) return d.toISOString().split('T')[0];
  return String(d);
};

const audit = claim.data.audit ?? null;
const ranAt = audit ? isoDate(audit.pipeline_run.ran_at) : null;
const reviewedAt = audit ? isoDate(audit.human_review.reviewed_at) : null;
---

<Base title={claim.data.title}>
  <article class="claim-detail">
    <Breadcrumb crumbs={claimCrumbs} />

    <header>
      {matchedCriteria && (
        <p class="criterion-ref">
          Criterion: <a href={`/criteria/${matchedCriteria.id}`}>{matchedCriteria.data.text}</a>
        </p>
      )}
      {showNotice && (
        <p class="status-notice">
          {isDraft ? 'This claim is a draft and has not been published.' : 'This claim is archived and may be outdated.'}
        </p>
      )}
      <h1>{claim.data.title}</h1>

      <div class="meta">
        <span
          class="verdict-badge"
          style={`background: ${verdictCssVar[claim.data.verdict] || "var(--color-verdict-unverified)"}`}
        >
          {claim.data.verdict}
        </span>

        <details class="confidence-details">
          <summary class="confidence">
            Confidence: {confidenceLabels[claim.data.confidence] || claim.data.confidence}
          </summary>
          <p class="confidence-explanation">
            {confidenceExplanations[claim.data.confidence]}
          </p>
        </details>

        <span class="as-of">
          As of {asOfDate}
        </span>

        <span class="category">
          {claim.data.category}
        </span>
      </div>

      <div class="entity-link">
        Entity: <a href={`/entities/${claim.data.entity}`}>{claim.data.entity}</a>
      </div>
    </header>

    <section class="rationale">
      <Content />
    </section>

    {claim.data.sources && claim.data.sources.length > 0 && (
      <section class="sources-section">
        <h2>Sources</h2>
        <ul class="source-list">
          {claim.data.sources.map((sourceRef: string) => (
            <li>
              <a href={`/sources/${sourceRef}`}>{sourceRef}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {audit && (
      <details class="audit-trail">
        <summary>Research process: {ranAt}, {audit.pipeline_run.model}</summary>

        <div class="audit-content">
          <section class="audit-section">
            <h3>Sources consulted</h3>
            <ul class="audit-source-list">
              {audit.sources_consulted.map((src) => (
                <li>
                  <a href={src.url}>{src.title}</a>
                  {' '}
                  <span class={src.ingested ? 'ingested-yes' : 'ingested-no'}>
                    {src.ingested ? 'ingested' : 'not ingested'}
                  </span>
                </li>
              ))}
            </ul>
          </section>

          <section class="audit-section">
            <h3>Verdict check</h3>
            {audit.audit === null ? (
              <p class="audit-muted">Auditor check unavailable.</p>
            ) : (
              <div>
                <p>Analyst: {audit.audit.analyst_verdict} ({audit.audit.analyst_confidence})</p>
                <p>Auditor: {audit.audit.auditor_verdict} ({audit.audit.auditor_confidence})</p>
                <p class={audit.audit.verdict_agrees ? 'audit-agrees' : 'audit-disagrees'}>
                  {audit.audit.verdict_agrees ? 'Verdicts agree' : 'Verdicts differ'}
                </p>
                {audit.audit.needs_review && (
                  <p class="audit-muted">Flagged for human review</p>
                )}
              </div>
            )}
          </section>

          <section class="audit-section">
            <h3>Human review</h3>
            {reviewedAt ? (
              <p>Reviewed {reviewedAt}{audit.human_review.reviewer ? ` by ${audit.human_review.reviewer}` : ''}</p>
            ) : (
              <p class="audit-muted">Pending human review</p>
            )}
          </section>
        </div>
      </details>
    )}

    <section class="review-info">
      <h2>Review cadence</h2>
      <p>This claim is reviewed every {claim.data.recheck_cadence_days} days.</p>
    </section>
  </article>
</Base>

<style>
  .claim-detail header {
    margin-bottom: var(--space-xl);
  }

  .status-notice {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-text-muted);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    padding: var(--space-xs) var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .criterion-ref {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-faint);
    margin-bottom: var(--space-sm);
  }

  .criterion-ref a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .criterion-ref a:hover {
    text-decoration: underline;
  }

  .claim-detail h1 {
    margin-bottom: var(--space-md);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .verdict-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: bold;
    color: var(--color-on-badge);
    text-transform: uppercase;
  }

  .confidence,
  .as-of,
  .category {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .confidence-details {
    font-size: var(--font-size-sm);
  }

  .confidence-details summary {
    list-style: none;
    cursor: pointer;
  }

  .confidence-details summary::-webkit-details-marker {
    display: none;
  }

  .confidence-explanation {
    margin: var(--space-xs) 0 0;
    padding: var(--space-xs) var(--space-sm);
    border-left: 2px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    line-height: 1.5;
  }

  .entity-link {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .rationale {
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  .rationale :global(h2),
  .rationale :global(h3) {
    margin-top: var(--space-lg);
  }

  .sources-section {
    margin-bottom: var(--space-xl);
  }

  .source-list {
    list-style: none;
    padding: 0;
  }

  .source-list li {
    padding: 0.4rem 0;
  }

  .source-list li::before {
    content: "\2192 ";
    color: var(--color-text-faint);
  }

  .review-info {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-md);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .review-info h2 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-xs);
  }

  .audit-trail {
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-xl);
    border-left: 2px solid var(--color-border);
    padding-left: var(--space-sm);
  }

  .audit-trail summary {
    list-style: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: var(--space-xs) 0;
  }

  .audit-trail summary::-webkit-details-marker {
    display: none;
  }

  .audit-trail summary::before {
    content: '+ ';
    color: var(--color-text-faint);
  }

  .audit-trail[open] summary::before {
    content: '- ';
  }

  .audit-content {
    padding-top: var(--space-sm);
  }

  .audit-section {
    margin-bottom: var(--space-md);
  }

  .audit-section h3 {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .audit-source-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .audit-source-list li {
    padding: 0.2rem 0;
  }

  .ingested-yes {
    color: var(--color-text-faint);
    font-size: var(--font-size-xs);
  }

  .ingested-no {
    color: var(--color-text-faint);
    font-size: var(--font-size-xs);
    font-style: italic;
  }

  .audit-agrees {
    color: var(--color-verdict-true, green);
  }

  .audit-disagrees {
    color: var(--color-verdict-mixed, orange);
  }

  .audit-muted {
    color: var(--color-text-faint);
    font-style: italic;
  }
</style>
