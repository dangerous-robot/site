---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
import PageHeader from "../../components/PageHeader.astro";
import VerdictBadge from "../../components/VerdictBadge.astro";
import { getEntityParent } from "../../lib/entityTypes";
import { VERDICT_RATINGS, VERDICT_LABELS, type Verdict } from "../../lib/verdict";
import { shouldNoindex } from "../../lib/seo";
import {
  CAPPED_VERIFICATION_LEVELS,
  VERIFICATION_LEVEL_GLOSS,
  VERIFICATION_LEVEL_LABELS,
  countSourcesByIndependence,
  formatSourceCounts,
  type VerificationLevel,
} from "../../lib/sourceQuality";

export async function getStaticPaths() {
  const claims = await getCollection("claims");
  return claims.map((claim) => ({
    params: { slug: claim.id },
    props: { claim },
  }));
}

const { claim } = Astro.props;
const { Content } = await render(claim);

const [criteria, entities, allSources] = await Promise.all([
  getCollection("criteria"),
  getCollection("entities"),
  getCollection("sources"),
]);
const stem = claim.id.split("/").pop() ?? claim.id;
const criteriaSlug = claim.data.criteria_slug ?? stem;
const matchedCriteria = criteria.find(s => s.id === criteriaSlug);

const entityEntry = entities.find(e => e.id === claim.data.entity) ?? null;
const typeParent = entityEntry ? getEntityParent(entityEntry.data.type) : null;
const entityLabel = entityEntry?.data.name ?? claim.data.entity;

const claimCrumbs = [
  { label: "Home", href: "/" },
  ...(typeParent ? [typeParent] : []),
  { label: entityLabel, href: `/entities/${claim.data.entity}` },
];

const confidenceLabels: Record<string, string> = {
  high: "High",
  medium: "Medium",
  low: "Low",
};

const asOfDate = claim.data.as_of instanceof Date
  ? claim.data.as_of.toISOString().split("T")[0]
  : String(claim.data.as_of);

const isDraft = claim.data.status === 'draft';
const isArchived = claim.data.status === 'archived';
const showNotice = isDraft || isArchived;

const isoDate = (d: Date | string | null | undefined): string | null => {
  if (!d) return null;
  if (d instanceof Date) return d.toISOString().split('T')[0];
  return String(d);
};

const audit = claim.data.audit ?? null;
const ranAt = audit ? isoDate(audit.pipeline_run.ran_at) : null;
const reviewedAt = audit ? isoDate(audit.human_review.reviewed_at) : null;

const sourceMap = new Map(allSources.map(s => [s.id, s]));

const verificationLevel = claim.data.verification_level as VerificationLevel | undefined;
const verificationLabel = verificationLevel ? VERIFICATION_LEVEL_LABELS[verificationLevel] : null;
const verificationGloss = verificationLevel ? VERIFICATION_LEVEL_GLOSS[verificationLevel] : null;
const isCapped = !!verificationLevel && CAPPED_VERIFICATION_LEVELS.has(verificationLevel);
const capRationale = isCapped ? claim.data.cap_rationale : null;
const sourceCounts = countSourcesByIndependence(
  claim.data.sources ?? [],
  sourceMap,
  claim.data.source_overrides,
);
const sourceCountText = formatSourceCounts(sourceCounts);

const isReviewed = !!(audit?.human_review.reviewer);

const claimDescription = claim.data.takeaway
  ?? `${entityLabel}: ${claim.data.title}`.slice(0, 155);

const claimPageTitle = claim.data.seo_title ?? claim.data.title;

const claimReview = {
  "@context": "https://schema.org",
  "@type": "ClaimReview",
  "url": Astro.url.href,
  "claimReviewed": claim.data.title,
  "datePublished": asOfDate,
  "author": {
    "@type": "Organization",
    "name": "Dangerous Robot",
    "url": "https://dangerousrobot.org",
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": VERDICT_RATINGS[claim.data.verdict as Verdict] ?? 3,
    "bestRating": 5,
    "worstRating": 1,
    "alternateName": VERDICT_LABELS[claim.data.verdict as Verdict] ?? claim.data.verdict,
  },
};
---

<Base title={claimPageTitle} description={claimDescription} noindex={shouldNoindex(Astro.url.pathname)}>
  <article class="claim-detail">
    {showNotice && (
      <p class="status-notice">
        {isDraft ? 'This claim is a draft and has not been published.' : 'This claim is archived and may be outdated.'}
      </p>
    )}
    <PageHeader crumbs={claimCrumbs} type="claim" title={claim.data.title}>
      <div class="meta">
        <VerdictBadge verdict={claim.data.verdict} />
        <span class="confidence">{confidenceLabels[claim.data.confidence] || claim.data.confidence} confidence</span>
        <span class="as-of">{asOfDate}</span>
        <span class={isReviewed ? "review-state reviewed" : "review-state unreviewed"}>
          {isReviewed ? "✓ Reviewed" : "Unreviewed"}
        </span>
      </div>
      {claim.data.takeaway && (
        <p class="takeaway">{claim.data.takeaway}</p>
      )}
    </PageHeader>

    {(verificationLabel || sourceCounts.total > 0) && (
      <section class="source-quality" aria-label="Source quality">
        {verificationLabel && (
          <div class="verification">
            <span class={`verification-label level-${verificationLevel}`}>{verificationLabel}</span>
            {verificationGloss && (
              <span class="verification-gloss">{verificationGloss}</span>
            )}
          </div>
        )}
        {sourceCounts.total > 0 && (
          <p class="source-count">{sourceCountText}</p>
        )}
        {capRationale && (
          <p class="cap-rationale">{capRationale}</p>
        )}
      </section>
    )}

    <section class="rationale">
      <Content />
    </section>

    {claim.data.sources && claim.data.sources.length > 0 && (
      <section class="sources-section">
        <h2>Sources</h2>
        <ul class="source-list">
          {claim.data.sources.map((sourceRef: string) => (
            <li>
              <a href={`/sources/${sourceRef}`}>{sourceRef}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {audit && (
      <details class="audit-trail">
        <summary>Research process · {ranAt} · {audit.pipeline_run.agents.join(', ')}</summary>

        <div class="audit-content">
          <section class="audit-section">
            <h3>Sources consulted</h3>
            <ul class="audit-source-list">
              {audit.sources_consulted.map((src) => {
                const meta = sourceMap.get(src.id);
                return (
                  <li>
                    {meta
                      ? <a href={`/sources/${src.id}`}>{src.title}</a>
                      : <a href={src.url} target="_blank" rel="noopener noreferrer">{src.title} ↗</a>}
                    {meta && (
                      <span class="source-meta">
                        {meta.data.kind}{meta.data.source_type ? ` · ${meta.data.source_type}` : ''} · {meta.data.publisher}
                      </span>
                    )}
                  </li>
                );
              })}
            </ul>
          </section>

          {audit.models_used && Object.keys(audit.models_used).length > 0 && (
            <section class="audit-section">
              <h3>Models used</h3>
              <ul class="audit-models-list">
                {Object.entries(audit.models_used).map(([agent, m]) => (
                  <li><code>{agent}</code>: <code>{m}</code></li>
                ))}
              </ul>
            </section>
          )}

          <section class="audit-section">
            <h3>Verdict check</h3>
            {audit.audit === null ? (
              <p class="audit-muted">Auditor check unavailable.</p>
            ) : (
              <div>
                <p>Analyst: {audit.audit.analyst_verdict} ({audit.audit.analyst_confidence})</p>
                <p>Auditor: {audit.audit.auditor_verdict} ({audit.audit.auditor_confidence})</p>
                <p class={audit.audit.verdict_agrees ? 'audit-agrees' : 'audit-disagrees'}>
                  {audit.audit.verdict_agrees ? 'Verdicts agree' : 'Verdicts differ'}
                </p>
                {audit.audit.needs_review && (
                  <p class="audit-muted">Flagged for human review</p>
                )}
              </div>
            )}
          </section>

          <section class="audit-section">
            <h3>Human review</h3>
            {reviewedAt ? (
              <p>Reviewed {reviewedAt}{audit.human_review.reviewer ? ` by ${audit.human_review.reviewer}` : ''}</p>
            ) : (
              <p class="audit-muted">Pending human review</p>
            )}
          </section>
        </div>
      </details>
    )}

    {matchedCriteria && (
      <p class="criterion-ref">
        Criterion: <a href={`/criteria/${matchedCriteria.id}`}>{matchedCriteria.data.text}</a>
      </p>
    )}

    <section class="review-info">
      <h2>Review cadence</h2>
      <p>This claim is reviewed every {claim.data.recheck_cadence_days} days.</p>
    </section>

    {!isDraft && !isArchived && (
      <script type="application/ld+json" set:html={JSON.stringify(claimReview)} />
    )}
  </article>
</Base>

<style>
  .status-notice {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-text-muted);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    padding: var(--space-xs) var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .criterion-ref {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-faint);
    margin-bottom: var(--space-sm);
  }

  .criterion-ref a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .criterion-ref a:hover {
    text-decoration: underline;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .confidence, .as-of { color: var(--color-text-muted); font-size: var(--font-size-sm); }

  .takeaway {
    font-size: var(--font-size-md);
    color: var(--color-text);
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-sm);
    margin: var(--space-sm) 0 var(--space-md);
  }

  .source-quality {
    margin: 0 0 var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 4px;
  }

  .verification {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: baseline;
    margin-bottom: 0.4rem;
  }

  .verification-label {
    font-weight: 600;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.05em 0.55em;
    border-radius: 3px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
  }

  .verification-label.level-claimed,
  .verification-label.level-self-reported {
    border-color: var(--color-text-faint);
    color: var(--color-text-muted);
  }

  .verification-gloss {
    color: var(--color-text);
    font-size: var(--font-size-sm);
    line-height: 1.4;
  }

  .source-count {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    margin: 0;
  }

  .cap-rationale {
    margin: 0.5rem 0 0;
    padding: var(--space-xs) var(--space-sm);
    border-left: 2px solid var(--color-text-faint);
    color: var(--color-text);
    font-size: var(--font-size-sm);
    line-height: 1.5;
    background: var(--color-bg);
  }

  .review-state { font-size: var(--font-size-sm); }
  .review-state.reviewed { color: var(--color-text-muted); }
  .review-state.unreviewed {
    color: var(--color-text);
    border: 1px solid var(--color-text-faint);
    border-radius: 999px;
    padding: 0.1em 0.6em;
  }

  .source-meta { color: var(--color-text-faint); font-size: var(--font-size-xs); margin-left: 0.4em; }

  .rationale {
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  .rationale :global(h2),
  .rationale :global(h3) {
    margin-top: var(--space-lg);
  }

  .sources-section {
    margin-bottom: var(--space-xl);
  }

  .source-list {
    list-style: none;
    padding: 0;
  }

  .source-list li {
    padding: 0.4rem 0;
  }

  .source-list li::before {
    content: "\2192 ";
    color: var(--color-text-faint);
  }

  .review-info {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-md);
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .review-info h2 {
    font-size: var(--font-size-base);
    margin-bottom: var(--space-xs);
  }

  .audit-trail {
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-xl);
    border-left: 2px solid var(--color-border);
    padding-left: var(--space-sm);
  }

  .audit-trail summary {
    list-style: none;
    cursor: pointer;
    color: var(--color-text-muted);
    padding: var(--space-xs) 0;
  }

  .audit-trail summary::-webkit-details-marker {
    display: none;
  }

  .audit-trail summary::before {
    content: '+ ';
    color: var(--color-text-faint);
  }

  .audit-trail[open] summary::before {
    content: '- ';
  }

  .audit-content {
    padding-top: var(--space-sm);
  }

  .audit-section {
    margin-bottom: var(--space-md);
  }

  .audit-section h3 {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .audit-source-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .audit-source-list li {
    padding: 0.2rem 0;
  }

  .audit-agrees {
    color: var(--color-verdict-true, green);
  }

  .audit-disagrees {
    color: var(--color-verdict-mixed, orange);
  }

  .audit-muted {
    color: var(--color-text-faint);
    font-style: italic;
  }
</style>
