---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { buildCriteriaIndex } from '../../lib/criteria';
import { CATEGORY_LABELS } from '../../lib/research';
import EmptyState from '../../components/EmptyState.astro';
import FilterBar from '../../components/FilterBar.astro';

const criteria = await getCollection('criteria');
const claims = await getCollection('claims', ({ data }) => data.status === 'published');
const criteriaIndex = buildCriteriaIndex(claims);

const rows = criteria.map(std => {
  const byEntity = criteriaIndex.get(std.id) ?? new Map();
  const coverageCount = byEntity.size;
  const totalClaims = [...byEntity.values()].flat().length;
  return {
    id: std.id,
    slug: std.id,
    text: std.data.text,
    topics: std.data.topics,
    entityType: std.data.entity_type,
    core: std.data.core,
    coverageCount,
    totalClaims,
  };
}).sort((a, b) => a.text.localeCompare(b.text));

const topicFacet = {
  id: 'topic',
  label: 'Topic',
  values: Object.entries(CATEGORY_LABELS).map(([v, label]) => ({ value: v, label })),
};
const coreFacet = {
  id: 'core',
  label: 'Core',
  values: [{ value: 'true', label: 'Core only' }],
};
---
<Base title="Criteria" layout="wide">
  <h1>Criteria</h1>
  <p class="disclaimer">Criteria are the questions we ask of every company and product. Each criterion links to the claims filed against it across all entities.</p>
  <FilterBar
    total={rows.length}
    searchPlaceholder="Search criteria…"
    searchDataAttr="data-text"
    facets={[topicFacet, coreFacet]}
  />
  <div class="criteria-list">
    {/* `data-topic` exposes the first topic only: FilterBar matches one
        attribute value per facet. Multi-topic faceting is a known
        follow-up (same workaround in src/components/ClaimRow.astro). */}
    {rows.map(row => (
      <a
        href={`/criteria/${row.slug}`}
        class="criteria-row"
        data-filterable
        data-text={row.text.toLowerCase()}
        data-topic={row.topics[0]}
        data-core={row.core ? 'true' : 'false'}
      >
        <span class="std-text">{row.text}</span>
        <span class="std-meta">
          <span class="category-label">{row.topics.map(t => CATEGORY_LABELS[t as keyof typeof CATEGORY_LABELS] ?? t).join(', ')}</span>
          <span class="coverage">{row.coverageCount} assessed · {row.totalClaims} claims</span>
        </span>
      </a>
    ))}
  </div>
  <div id="filter-empty" hidden>
    <EmptyState message="No criteria match this filter." />
  </div>
</Base>
<style>
.disclaimer { font-size: var(--font-size-sm); color: var(--color-text-faint); margin-bottom: var(--space-md); }
.criteria-list { display: flex; flex-direction: column; }
.criteria-row {
  display: flex; flex-direction: column; gap: var(--space-xs);
  padding: var(--space-md);
  border-bottom: 1px solid var(--color-border);
  text-decoration: none; color: inherit;
}
.criteria-row:hover { background: var(--color-surface); }
.std-text { font-weight: 500; color: var(--color-text); }
.std-meta { display: flex; gap: var(--space-md); font-size: var(--font-size-xs); color: var(--color-text-muted); }
.coverage { color: var(--color-text-faint); }
</style>
