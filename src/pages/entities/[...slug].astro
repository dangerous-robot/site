---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entities = await getCollection("entities");
  return entities.map((entity) => ({
    params: { slug: entity.id },
    props: { entity },
  }));
}

const { entity } = Astro.props;
const { Content } = await render(entity);

// Find all claims related to this entity
const allClaims = await getCollection("claims");
const relatedClaims = allClaims.filter(
  (claim) => claim.data.entity === entity.id
);

const verdictCssVar: Record<string, string> = {
  true: "var(--color-verdict-true)",
  "mostly-true": "var(--color-verdict-mostly-true)",
  mixed: "var(--color-verdict-mixed)",
  "mostly-false": "var(--color-verdict-mostly-false)",
  false: "var(--color-verdict-false)",
  unverified: "var(--color-verdict-unverified)",
};

const kindLabels: Record<string, string> = {
  company: "Company",
  product: "Product",
  topic: "Topic",
};
---

<Base title={entity.data.name}>
  <article class="entity-detail">
    <header>
      <h1>{entity.data.name}</h1>

      <div class="meta">
        <span class="kind-label">
          {kindLabels[entity.data.type] || entity.data.type}
        </span>

        {entity.data.website && (
          <a href={entity.data.website} target="_blank" rel="noopener noreferrer" class="website-link">
            {entity.data.website} &#8599;
          </a>
        )}
      </div>

      <p class="description">{entity.data.description}</p>
    </header>

    <section class="body-content">
      <Content />
    </section>

    <section class="related-claims">
      <h2>Claims</h2>
      {relatedClaims.length === 0 ? (
        <p class="empty">No claims for this entity yet.</p>
      ) : (
        <ul class="claim-list">
          {relatedClaims.map((claim) => (
            <li>
              <span
                class="verdict-badge"
                style={`background: ${verdictCssVar[claim.data.verdict] || "var(--color-verdict-unverified)"}`}
              >
                {claim.data.verdict}
              </span>
              <a href={`/claims/${claim.id}`}>
                {claim.data.title}
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </article>
</Base>

<style>
  .entity-detail header {
    margin-bottom: var(--space-xl);
  }

  .entity-detail h1 {
    margin-bottom: 0.75rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .kind-label {
    background: var(--color-surface);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    font-weight: bold;
  }

  .website-link {
    font-size: var(--font-size-sm);
  }

  .description {
    color: var(--color-text-muted);
    font-size: var(--font-size-base);
  }

  .body-content {
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  .body-content :global(h2),
  .body-content :global(h3) {
    margin-top: var(--space-lg);
  }

  .related-claims {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }

  .related-claims h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-md);
  }

  .empty {
    color: var(--color-text-faint);
    font-style: italic;
  }

  .claim-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .claim-list li {
    padding: var(--space-sm) 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .verdict-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-2xs);
    font-weight: bold;
    color: var(--color-on-badge);
    text-transform: uppercase;
    white-space: nowrap;
    min-width: 5.5rem;
    text-align: center;
  }
</style>
