---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
import { buildStandardsIndex } from "../../lib/standards";
import { CATEGORY_LABELS } from "../../lib/research";
import VerdictBadge from "../../components/VerdictBadge.astro";
import NotAssessedCell from "../../components/NotAssessedCell.astro";

export async function getStaticPaths() {
  const entities = await getCollection("entities");
  return entities.map((entity) => ({
    params: { slug: entity.id },
    props: { entity },
  }));
}

const { entity } = Astro.props;
const { Content } = await render(entity);

const allClaims = await getCollection("claims", ({ data }) => data.status === "published");
const relatedClaims = allClaims.filter(
  (claim) => claim.data.entity === entity.id
);

// Group claims by category
const claimsByCategory = new Map<string, typeof relatedClaims>();
for (const claim of relatedClaims) {
  const cat = claim.data.category;
  if (!claimsByCategory.has(cat)) claimsByCategory.set(cat, []);
  claimsByCategory.get(cat)!.push(claim);
}
const categoriesWithClaims = [...claimsByCategory.keys()].sort();

// Standards-applied section
const standards = await getCollection("standards");
const standardsIndex = buildStandardsIndex(allClaims);

// Filter standards matching this entity's type
const applicableStandards = standards.filter(
  std => std.data.entity_type === entity.data.type
);

// Group applicable standards by category
const stdsByCategory = new Map<string, typeof applicableStandards>();
for (const std of applicableStandards) {
  const cat = std.data.category;
  if (!stdsByCategory.has(cat)) stdsByCategory.set(cat, []);
  stdsByCategory.get(cat)!.push(std);
}
const stdCategoriesSorted = [...stdsByCategory.keys()].sort();

const kindLabels: Record<string, string> = {
  company: "Company",
  product: "Product",
  topic: "Topic",
};
---

<Base title={entity.data.name}>
  <article class="entity-detail">
    <header>
      <h1>{entity.data.name}</h1>

      <div class="meta">
        <span class="kind-label">
          {kindLabels[entity.data.type] || entity.data.type}
        </span>

        {entity.data.website && (
          <a href={entity.data.website} target="_blank" rel="noopener noreferrer" class="website-link">
            {entity.data.website} &#8599;
          </a>
        )}
      </div>

      <p class="description">{entity.data.description}</p>
    </header>

    <section class="body-content">
      <Content />
    </section>

    <section class="related-claims">
      <h2>Claims</h2>
      {relatedClaims.length === 0 ? (
        <p class="empty">No claims for this entity yet.</p>
      ) : (
        categoriesWithClaims.map(cat => (
          <div class="category-group">
            <h3 class="category-heading">
              {CATEGORY_LABELS[cat as keyof typeof CATEGORY_LABELS] ?? cat}
            </h3>
            <ul class="claim-list">
              {claimsByCategory.get(cat)!.map((claim) => (
                <li>
                  <VerdictBadge verdict={claim.data.verdict} size="sm" />
                  <a href={`/claims/${claim.id}`}>
                    {claim.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      )}
    </section>

    {applicableStandards.length > 0 && (
      <section class="standards-applied">
        <h2>Standards</h2>
        <p class="standards-note">How this {entity.data.type} fares against applicable claim templates.</p>
        {stdCategoriesSorted.map(cat => (
          <div class="std-category-group">
            <h3 class="std-category-heading">
              {CATEGORY_LABELS[cat as keyof typeof CATEGORY_LABELS] ?? cat}
            </h3>
            <div class="std-rows">
              {stdsByCategory.get(cat)!.map(std => {
                const byEntity = standardsIndex.get(std.id) ?? new Map();
                const entityClaims = byEntity.get(entity.id) ?? [];
                const topClaim = entityClaims[0];
                return (
                  <div class="std-row">
                    <a href={`/standards/${std.id}`} class="std-text">{std.data.text}</a>
                    <div class="std-verdict">
                      {topClaim
                        ? <VerdictBadge verdict={topClaim.verdict} size="sm" />
                        : <NotAssessedCell />
                      }
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        ))}
      </section>
    )}
  </article>
</Base>

<style>
  .entity-detail header {
    margin-bottom: var(--space-xl);
  }

  .entity-detail h1 {
    margin-bottom: 0.75rem;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .kind-label {
    background: var(--color-surface);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    font-weight: bold;
  }

  .website-link {
    font-size: var(--font-size-sm);
  }

  .description {
    color: var(--color-text-muted);
    font-size: var(--font-size-base);
  }

  .body-content {
    margin-bottom: var(--space-xl);
    line-height: 1.7;
  }

  .body-content :global(h2),
  .body-content :global(h3) {
    margin-top: var(--space-lg);
  }

  .related-claims {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .related-claims h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-md);
  }

  .category-group {
    margin-bottom: var(--space-lg);
  }

  .category-heading {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-faint);
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .empty {
    color: var(--color-text-faint);
    font-style: italic;
  }

  .claim-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .claim-list li {
    padding: var(--space-sm) 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .claim-list li:last-child {
    border-bottom: none;
  }

  /* Standards applied section */
  .standards-applied {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }

  .standards-applied h2 {
    font-size: 1.2rem;
    margin-bottom: var(--space-xs);
  }

  .standards-note {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .std-category-group {
    margin-bottom: var(--space-lg);
  }

  .std-category-heading {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-faint);
    margin-bottom: var(--space-sm);
    font-weight: 600;
  }

  .std-rows {
    display: flex;
    flex-direction: column;
  }

  .std-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .std-row:last-child {
    border-bottom: none;
  }

  .std-text {
    flex: 1;
    font-size: var(--font-size-sm);
    color: var(--color-text);
    text-decoration: none;
  }

  .std-text:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .std-verdict {
    flex-shrink: 0;
  }
</style>
