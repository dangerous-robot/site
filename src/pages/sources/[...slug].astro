---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
import { buildCitationIndex } from "../../lib/citations";
import ClaimRow from "../../components/ClaimRow.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

export async function getStaticPaths() {
  const sources = await getCollection("sources");
  return sources.map((source) => ({
    params: { slug: source.id },
    props: { source },
  }));
}

const { source } = Astro.props;
const { Content } = await render(source);

// Reverse citation lookup
const allClaims = await getCollection("claims", ({ data }) => data.status === "published");
const citationIndex = buildCitationIndex(allClaims);
const citingClaims = citationIndex.get(source.id) ?? [];

const kindCssVar: Record<string, string> = {
  report: "var(--color-kind-report)",
  article: "var(--color-kind-article)",
  documentation: "var(--color-kind-documentation)",
  dataset: "var(--color-kind-dataset)",
  blog: "var(--color-kind-blog)",
  video: "var(--color-kind-video)",
  index: "var(--color-kind-index)",
};

const sourceTypeLabel: Record<string, string> = {
  primary: "Primary",
  secondary: "Secondary",
  tertiary: "Tertiary",
};

const sourceTypeTooltip: Record<string, string> = {
  primary: "Company disclosures, official documentation, regulatory filings",
  secondary: "Journalism, independent research, academic papers",
  tertiary: "Advocacy organizations, opinion pieces, review aggregators",
};

const accessedDate = source.data.accessed_date instanceof Date
  ? source.data.accessed_date.toISOString().split("T")[0]
  : String(source.data.accessed_date);

const publishedDate = source.data.published_date instanceof Date
  ? source.data.published_date.toISOString().split("T")[0]
  : source.data.published_date
    ? String(source.data.published_date)
    : null;

const sourceCrumbs = [
  { label: "Home", href: "/" },
  { label: "Sources", href: "/sources" },
  { label: source.data.title },
];

const sourceDescription = source.data.summary
  ?? `${source.data.publisher} — ${source.data.kind}: ${source.data.title}`.slice(0, 155);
---

<Base title={source.data.title} description={sourceDescription}>
  <article class="source-detail">
    <Breadcrumb crumbs={sourceCrumbs} />
    <header>
      <h1>{source.data.title}</h1>

      <div class="meta">
        {source.data.source_type && (
          <span
            class={`source-type-badge source-type-${source.data.source_type}`}
            title={sourceTypeTooltip[source.data.source_type]}
          >
            {sourceTypeLabel[source.data.source_type]}
          </span>
        )}

        <span
          class="kind-badge"
          style={`background: ${kindCssVar[source.data.kind] || "var(--color-text-faint)"}`}
        >
          {source.data.kind}
        </span>

        <span class="publisher">{source.data.publisher}</span>
      </div>

      <div class="dates">
        {publishedDate && <span>Published: {publishedDate}</span>}
        <span>Accessed: {accessedDate}</span>
      </div>

      <div class="links">
        <a href={source.data.url} target="_blank" rel="noopener noreferrer">
          Original source &#8599;
        </a>
        {source.data.archived_url && (
          <a href={source.data.archived_url} target="_blank" rel="noopener noreferrer">
            Archived copy &#8599;
          </a>
        )}
      </div>
    </header>

    <section class="summary">
      <h2>Summary</h2>
      <p>{source.data.summary}</p>
    </section>

    {source.data.key_quotes && source.data.key_quotes.length > 0 && (
      <section class="key-quotes">
        <h2>Key quotes</h2>
        {source.data.key_quotes.map((quote: string) => (
          <blockquote>{quote}</blockquote>
        ))}
      </section>
    )}

    {citingClaims.length > 0 && (
      <section class="citing-claims">
        <h2>Claims using this source</h2>
        <div class="claims-list">
          {citingClaims.map(entry => (
            <ClaimRow
              id={entry.id}
              title={entry.title}
              verdict={entry.verdict}
              entity={entry.entity}
              topics={entry.topics}
            />
          ))}
        </div>
      </section>
    )}

    <section class="body-content">
      <Content />
    </section>
  </article>
</Base>

<style>
  .source-detail header {
    margin-bottom: var(--space-xl);
  }

  .source-detail h1 {
    margin-bottom: var(--space-md);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .source-type-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-2xs);
    font-weight: bold;
    color: var(--color-on-badge);
    text-transform: uppercase;
    cursor: default;
  }

  .source-type-primary {
    background: hsl(210 55% 32%);
  }

  .source-type-secondary {
    background: hsl(220 18% 36%);
  }

  .source-type-tertiary {
    background: hsl(220 10% 28%);
  }

  .kind-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-2xs);
    font-weight: bold;
    color: var(--color-on-badge);
    text-transform: uppercase;
  }

  .publisher {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .dates {
    display: flex;
    gap: var(--space-lg);
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .links {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .links a {
    font-size: var(--font-size-sm);
  }

  .summary {
    margin-bottom: var(--space-xl);
  }

  .summary h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
  }

  .summary p {
    color: var(--color-text-muted);
  }

  .key-quotes {
    margin-bottom: var(--space-xl);
  }

  .key-quotes h2 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  /* blockquote uses global.css token styles */

  .citing-claims {
    margin-bottom: var(--space-xl);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
  }

  .citing-claims h2 {
    font-size: 1.1rem;
    margin-bottom: var(--space-md);
  }

  .body-content {
    line-height: 1.7;
  }

  .body-content :global(h2),
  .body-content :global(h3) {
    margin-top: var(--space-lg);
  }
</style>
